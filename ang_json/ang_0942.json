{
  "ang": 942,
  "line_count": 56,
  "lines": [
    {
      "index": 1,
      "verse_id": 40162,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਸਬਦੈ ਸਭਿ ਦੂਜੈ ਲਾਗੇ ਦੇਖਹੁ ਰਿਦੈ ਬੀਚਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin sabdē sabh dūjē lāgē dēkhah ridē bīchār",
      "translation_ru": "Без Шабда все привязаны к двойственности; посмотри и обдумай это в сердце."
    },
    {
      "index": 2,
      "verse_id": 40163,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਵਡੇ ਸੇ ਵਡਭਾਗੀ ਜਿਨੀ ਸਚੁ ਰਖਿਆ ਉਰ ਧਾਰਿ ॥੩੪॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak vaḍē sē vaḍbhāgī jinī sach rakhyā ur dhār",
      "translation_ru": "О Нанак, велики и весьма удачливы те, кто удержал Истину в сердце."
    },
    {
      "index": 3,
      "verse_id": 40164,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਰਤਨੁ ਲਹੈ ਲਿਵ ਲਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh ratan lahē liv lāe",
      "translation_ru": "Тот, кто идёт лицом к Гуру, соединяя сознание с Господом, находит драгоценность Имени."
    },
    {
      "index": 4,
      "verse_id": 40165,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਖੈ ਰਤਨੁ ਸੁਭਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh parakhē ratan subhāe",
      "translation_ru": "Такой человек естественно, через свою внутреннюю любовь, узнаёт ценность этой драгоценности Имени."
    },
    {
      "index": 5,
      "verse_id": 40166,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੀ ਕਾਰ ਕਮਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāchī kār kamāe",
      "translation_ru": "Именно это истинное дело совершает гурмукх."
    },
    {
      "index": 6,
      "verse_id": 40167,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੇ ਮਨੁ ਪਤੀਆਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāchē man patīāe",
      "translation_ru": "Он приучает свой ум пребывать в Истинном Господе."
    },
    {
      "index": 7,
      "verse_id": 40168,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਅਲਖੁ ਲਖਾਏ ਤਿਸੁ ਭਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh alakh lakhāe tis bhāvē",
      "translation_ru": "Когда тому Господу это угодно, гурмукх даёт и другим понимание качеств Непостижимого."
    },
    {
      "index": 8,
      "verse_id": 40169,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਚੋਟ ਨ ਖਾਵੈ ॥੩੫॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak gurmukh choṭ na khāvē",
      "translation_ru": "О Нанак, тот, кто идёт по слову Гуру, не получает ударов от пороков."
    },
    {
      "index": 9,
      "verse_id": 40170,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਦਾਨੁ ਇਸਨਾਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh nām dān isnān",
      "translation_ru": "У того, кто идёт путём Гуру, принятны повторение Имени, даяние и омовение."
    },
    {
      "index": 10,
      "verse_id": 40171,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਲਾਗੈ ਸਹਜਿ ਧਿਆਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh lāgē sahaj dhiān",
      "translation_ru": "Лишь в обращённости к Гуру сознание соединяется в состоянии духовной устойчивости."
    },
    {
      "index": 11,
      "verse_id": 40172,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਵੈ ਦਰਗਹ ਮਾਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh pāvē dargah mān",
      "translation_ru": "Гурмукх получает почёт в присутствии Господа."
    },
    {
      "index": 12,
      "verse_id": 40173,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਭਉ ਭੰਜਨੁ ਪਰਧਾਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh bhau bhañjan pardhān",
      "translation_ru": "Он встречает Господа, разрушающего страхи мира и являющегося Владыкой всех."
    },
    {
      "index": 13,
      "verse_id": 40174,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਕਰਣੀ ਕਾਰ ਕਰਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh karṇī kār karāe",
      "translation_ru": "Гурмукх побуждает и других совершать достойное дело — идти по повелению Гуру."
    },
    {
      "index": 14,
      "verse_id": 40175,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਮੇਲਿ ਮਿਲਾਏ ॥੩੬॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak gurmukh mēl milāe",
      "translation_ru": "О Нанак, так он соединяет их с единением с Господом."
    },
    {
      "index": 15,
      "verse_id": 40176,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਸਤ੍ਰ ਸਿਮ੍ਰਿਤਿ ਬੇਦ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāstar simrit bēd",
      "translation_ru": "Тот, кто идёт путём Гуру, словно уже постиг Шастры, Симрити и Веды."
    },
    {
      "index": 16,
      "verse_id": 40177,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਵੈ ਘਟਿ ਘਟਿ ਭੇਦ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh pāvē ghaṭ ghaṭ bhēd",
      "translation_ru": "Через повеление Гуру он понимает тайну Господа, присутствующего в каждом сердце."
    },
    {
      "index": 17,
      "verse_id": 40178,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਵੈਰ ਵਿਰੋਧ ਗਵਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh vēr virōdh gavāvē",
      "translation_ru": "Гурмукх отбрасывает вражду и противостояние к другим."
    },
    {
      "index": 18,
      "verse_id": 40179,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਗਲੀ ਗਣਤ ਮਿਟਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh saglī gaṇat miṭāvē",
      "translation_ru": "Он полностью стирает весь счёт обид и никогда не держит в уме чужой несправедливости."
    },
    {
      "index": 19,
      "verse_id": 40180,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਰਾਮ ਨਾਮ ਰੰਗਿ ਰਾਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh rām nām raṅg rātā",
      "translation_ru": "Гурмукх пребывает окрашенным любовью к Имени Господа."
    },
    {
      "index": 20,
      "verse_id": 40181,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਖਸਮੁ ਪਛਾਤਾ ॥੩੭॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak gurmukh khasam pachhātā",
      "translation_ru": "О Нанак, человек, обращённый к Гуру, распознал своего Господина — Господа."
    },
    {
      "index": 21,
      "verse_id": 40182,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਗੁਰ ਭਰਮੈ ਆਵੈ ਜਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin gur bharmē āvē jāe",
      "translation_ru": "Без прибежища у Сатгуру человек блуждает в майе и продолжает рождаться и умирать."
    },
    {
      "index": 22,
      "verse_id": 40183,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਗੁਰ ਘਾਲ ਨ ਪਵਈ ਥਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin gur ghāl na pavaī thāe",
      "translation_ru": "Без прибежища у Гуру никакое усилие не принимается, потому что Хоумэ остаётся внутри."
    },
    {
      "index": 23,
      "verse_id": 40184,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਗੁਰ ਮਨੂਆ ਅਤਿ ਡੋਲਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin gur manūā at ḍōlāe",
      "translation_ru": "Без Сатгуру этот беспокойный ум остаётся в сильных сомнениях."
    },
    {
      "index": 24,
      "verse_id": 40185,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਗੁਰ ਤ੍ਰਿਪਤਿ ਨਹੀ ਬਿਖੁ ਖਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin gur tripat nahī bikh khāe",
      "translation_ru": "Поедая яд, то есть наслаждаясь мирскими предметами, он всё равно не насыщается."
    },
    {
      "index": 25,
      "verse_id": 40186,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਗੁਰ ਬਿਸੀਅਰੁ ਡਸੈ ਮਰਿ ਵਾਟ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin gur bisīar ḍasē mar vāṭ",
      "translation_ru": "Без пути Гуру змея мирского влечения продолжает жалить, и человек духовно умирает посреди жизненного пути."
    },
    {
      "index": 26,
      "verse_id": 40187,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰ ਬਿਨੁ ਘਾਟੇ ਘਾਟ ॥੩੮॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak gur bin ghāṭē ghāṭ",
      "translation_ru": "О Нанак, без следования повелению Сатгуру человек терпит один духовный убыток за другим."
    },
    {
      "index": 27,
      "verse_id": 40188,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਸੁ ਗੁਰੁ ਮਿਲੈ ਤਿਸੁ ਪਾਰਿ ਉਤਾਰੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jis gur milē tis pār utārē",
      "translation_ru": "Того человека, кому встречается Сатгуру, он переправляет через труднопроходимый океан."
    },
    {
      "index": 28,
      "verse_id": 40189,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਵਗਣ ਮੇਟੈ ਗੁਣਿ ਨਿਸਤਾਰੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "avgaṇ mēṭē guṇ nistārē",
      "translation_ru": "Гуру стирает его недостатки и, наделяя добродетелью, спасает от пороков."
    },
    {
      "index": 29,
      "verse_id": 40190,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੁਕਤਿ ਮਹਾ ਸੁਖ ਗੁਰ ਸਬਦੁ ਬੀਚਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mukt mahā sukh gur sabad bīchār",
      "translation_ru": "Размышляя над Шабдом Сатгуру, он получает великое блаженство освобождения от уз майи."
    },
    {
      "index": 30,
      "verse_id": 40191,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਕਦੇ ਨ ਆਵੈ ਹਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh kadē na āvē hār",
      "translation_ru": "Гурмукх никогда не возвращается побеждённым в игре жизни."
    },
    {
      "index": 31,
      "verse_id": 40192,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਨੁ ਹਟੜੀ ਇਹੁ ਮਨੁ ਵਣਜਾਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tan haṭṛī ih man vaṇjārā",
      "translation_ru": "Гурмукх делает своё тело прекрасной лавкой, а ум — торговцем."
    },
    {
      "index": 32,
      "verse_id": 40193,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਸਹਜੇ ਸਚੁ ਵਾਪਾਰਾ ॥੩੯॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak sahjē sach vāpārā",
      "translation_ru": "О Нанак, пребывая в духовной устойчивости, он ведёт торговлю Истинным Именем Господа."
    },
    {
      "index": 33,
      "verse_id": 40194,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਬਾਂਧਿਓ ਸੇਤੁ ਬਿਧਾਤੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh bāndhiō sēt bidhātē",
      "translation_ru": "Творец построил мост в виде гурмукха через мировой океан."
    },
    {
      "index": 34,
      "verse_id": 40195,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਲੰਕਾ ਲੂਟੀ ਦੈਤ ਸੰਤਾਪੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "laṅkā lūṭī dēt santāpē",
      "translation_ru": "Как была разграблена Ланка и поражены ракшасы, так Гуру освобождает тело от власти похоти и прочих страстей."
    },
    {
      "index": 35,
      "verse_id": 40196,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮਚੰਦਿ ਮਾਰਿਓ ਅਹਿ ਰਾਵਣੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rāmchand māriō ah rāvaṇ",
      "translation_ru": "Как Рамчандра убил Равана, так гурмукх убивает змею-ум."
    },
    {
      "index": 36,
      "verse_id": 40197,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਭੇਦੁ ਬਭੀਖਣ ਗੁਰਮੁਖਿ ਪਰਚਾਇਣੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bhēd babhīkhaṇ gurmukh parchāiṇ",
      "translation_ru": "Наставление Сатгуру помогает победить ум так же, как тайна, раскрытая Бибхишаном, помогла победить Равана."
    },
    {
      "index": 37,
      "verse_id": 40198,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਇਰਿ ਪਾਹਣ ਤਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāir pāhaṇ tārē",
      "translation_ru": "Сатгуру переправляет через мировой океан даже каменносердечных."
    },
    {
      "index": 38,
      "verse_id": 40199,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਕੋਟਿ ਤੇਤੀਸ ਉਧਾਰੇ ॥੪੦॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh kōṭ tetīs udhārē",
      "translation_ru": "Через Гуру переправились тридцать три крора, то есть бесчисленные живые существа."
    },
    {
      "index": 39,
      "verse_id": 40200,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਚੂਕੈ ਆਵਣ ਜਾਣੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh chūkē āvaṇ jāṇ",
      "translation_ru": "У того, кто идёт по повелению Гуру, прекращается круг рождения и смерти."
    },
    {
      "index": 40,
      "verse_id": 40201,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਦਰਗਹ ਪਾਵੈ ਮਾਣੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh dargah pāvē māṇ",
      "translation_ru": "Гурмукх получает почёт в присутствии Господа."
    },
    {
      "index": 41,
      "verse_id": 40202,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਖੋਟੇ ਖਰੇ ਪਛਾਣੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh khōṭē kharē pachhāṇ",
      "translation_ru": "Гурмукх становится знающим различие между ложными и истинными делами."
    },
    {
      "index": 42,
      "verse_id": 40203,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਲਾਗੈ ਸਹਜਿ ਧਿਆਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh lāgē sahaj dhiān",
      "translation_ru": "Поэтому он не попадает в ложные дела, и его сознание остаётся соединённым в духовной устойчивости."
    },
    {
      "index": 43,
      "verse_id": 40204,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਦਰਗਹ ਸਿਫਤਿ ਸਮਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh dargah sifat samāe",
      "translation_ru": "Через восхваление Господа гурмукх пребывает в Его присутствии."
    },
    {
      "index": 44,
      "verse_id": 40205,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਬੰਧੁ ਨ ਪਾਇ ॥੪੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak gurmukh bandh na pāe",
      "translation_ru": "О Нанак, на пути жизни гурмукха не возникает преграды пороков."
    },
    {
      "index": 45,
      "verse_id": 40206,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਨਿਰੰਜਨ ਪਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh nām nirañjan pāe",
      "translation_ru": "Человек, идущий по повелению Гуру, получает Имя Нираджана, Господа, свободного от майи."
    },
    {
      "index": 46,
      "verse_id": 40207,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਹਉਮੈ ਸਬਦਿ ਜਲਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh haumē sabad jalāe",
      "translation_ru": "Через Шабд Гуру он сжигает свою Хоумэ."
    },
    {
      "index": 47,
      "verse_id": 40208,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੇ ਕੇ ਗੁਣ ਗਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāchē kē guṇ gāe",
      "translation_ru": "Обратившись к Гуру, человек поёт достоинства Истинного Господа."
    },
    {
      "index": 48,
      "verse_id": 40209,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੈ ਰਹੈ ਸਮਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāchē rahē samāe",
      "translation_ru": "Он остаётся погружённым в вечно пребывающего Истинного Господа."
    },
    {
      "index": 49,
      "verse_id": 40210,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚਿ ਨਾਮਿ ਪਤਿ ਊਤਮ ਹੋਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāch nām pat ūtam hōe",
      "translation_ru": "Оставаясь соединённым с Истинным Именем, гурмукх получает высокую честь."
    },
    {
      "index": 50,
      "verse_id": 40211,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਗਲ ਭਵਣ ਕੀ ਸੋਝੀ ਹੋਇ ॥੪੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak gurmukh sagal bhavaṇ kī sōjhī hōe",
      "translation_ru": "О Нанак, гурмукху приходит понимание всех миров: он осознаёт, что Господь присутствует во всех мирах."
    },
    {
      "index": 51,
      "verse_id": 40212,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਵਣ ਮੂਲੁ ਕਵਣ ਮਤਿ ਵੇਲਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kavaṇ mūl kavaṇ mat vēlā",
      "translation_ru": "Вопрос: каков корень жизни и какое учение следует принимать в это время человеческого рождения?"
    },
    {
      "index": 52,
      "verse_id": 40213,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤੇਰਾ ਕਵਣੁ ਗੁਰੂ ਜਿਸ ਕਾ ਤੂ ਚੇਲਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tērā kavaṇ gurū jis kā tū chēlā",
      "translation_ru": "Чьим учеником ты являешься, и кто твой Гуру?"
    },
    {
      "index": 53,
      "verse_id": 40214,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਵਣ ਕਥਾ ਲੇ ਰਹਹੁ ਨਿਰਾਲੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kavaṇ kathā lē rahah nirālē",
      "translation_ru": "Благодаря какому учению ты остаёшься отдельным и незапятнанным?"
    },
    {
      "index": 54,
      "verse_id": 40215,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੋਲੈ ਨਾਨਕੁ ਸੁਣਹੁ ਤੁਮ ਬਾਲੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bōlē nānak suṇah tum bālē",
      "translation_ru": "Нанак говорит: йоги сказали — слушай, о юный Нанак."
    },
    {
      "index": 55,
      "verse_id": 40216,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਏਸੁ ਕਥਾ ਕਾ ਦੇਇ ਬੀਚਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ēs kathā kā dēe bīchār",
      "translation_ru": "Объясни нам также смысл этого вопроса."
    },
    {
      "index": 56,
      "verse_id": 40217,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਭਵਜਲੁ ਸਬਦਿ ਲੰਘਾਵਣਹਾਰੁ ॥੪੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bhavjal sabad laṅghāvaṇhār",
      "translation_ru": "Объясни, как через Шабд Гуру способен переправить живое существо через океан мира."
    }
  ]
}
