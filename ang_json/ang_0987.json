{
  "ang": 987,
  "line_count": 59,
  "lines": [
    {
      "index": 1,
      "verse_id": 42064,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੂਝਤ ਦੀਪਕ ਮਿਲਤ ਤਿਲਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "būjhat dīpak milat tilat",
      "translation_ru": "Как гаснущая лампа, когда получает масло."
    },
    {
      "index": 2,
      "verse_id": 42065,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਲਤ ਅਗਨੀ ਮਿਲਤ ਨੀਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jalat agnī milat nīr",
      "translation_ru": "Как пылающий огонь, когда встречается с водой."
    },
    {
      "index": 3,
      "verse_id": 42066,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਬਾਰਿਕ ਮੁਖਹਿ ਖੀਰ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jēsē bārik mukhah khīr",
      "translation_ru": "Как молоко у уст ребёнка."
    },
    {
      "index": 4,
      "verse_id": 42067,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਰਣ ਮਹਿ ਸਖਾ ਭ੍ਰਾਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jēsē raṇ meh sakhā bhrāt",
      "translation_ru": "Как друг и брат на поле битвы."
    },
    {
      "index": 5,
      "verse_id": 42068,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਭੂਖੇ ਭੋਜਨ ਮਾਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jēsē bhūkhē bhojan māt",
      "translation_ru": "Как пища для голодного, дающая ему насыщение."
    },
    {
      "index": 6,
      "verse_id": 42069,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਕਿਰਖਹਿ ਬਰਸ ਮੇਘ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jēsē kirakhah baras mēgh",
      "translation_ru": "Как дождевое облако для посевов."
    },
    {
      "index": 7,
      "verse_id": 42070,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਪਾਲਨ ਸਰਨਿ ਸੇਂਘ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jēsē pālan saran seṅgh",
      "translation_ru": "Как защита того, кто пришёл под покров льва."
    },
    {
      "index": 8,
      "verse_id": 42071,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਰੁੜ ਮੁਖਿ ਨਹੀ ਸਰਪ ਤ੍ਰਾਸ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "garuṛ mukh nahī sarap trās",
      "translation_ru": "Как у змеи нет страха, когда она в устах Гаруды."
    },
    {
      "index": 9,
      "verse_id": 42072,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੂਆ ਪਿੰਜਰਿ ਨਹੀ ਖਾਇ ਬਿਲਾਸੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sūā piñjar nahī khāē bilās",
      "translation_ru": "Как попугай в клетке не вкушает наслаждений на свободе."
    },
    {
      "index": 10,
      "verse_id": 42073,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੋ ਆਂਡੋ ਹਿਰਦੇ ਮਾਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jēso āṇḍo hirdē māh",
      "translation_ru": "Как яйцо хранится внутри сердца."
    },
    {
      "index": 11,
      "verse_id": 42074,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੋ ਦਾਨੋ ਚਕੀ ਦਰਾਹਿ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jēso dāno chakī darāh",
      "translation_ru": "Как зерно, попавшее между жерновами мельницы."
    },
    {
      "index": 12,
      "verse_id": 42075,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਹੁਤੁ ਓਪਮਾ ਥੋਰ ਕਹੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bahut opmā thor kahī",
      "translation_ru": "Много сравнений можно привести, но сказано лишь немногое."
    },
    {
      "index": 13,
      "verse_id": 42076,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਅਗਮ ਅਗਮ ਅਗਾਧਿ ਤੁਹੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har agam agam agādh tuhī",
      "translation_ru": "О Хари, Ты непостижимый, непостижимый, бездонно глубокий."
    },
    {
      "index": 14,
      "verse_id": 42077,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਊਚ ਮੂਚੌ ਬਹੁ ਅਪਾਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ūch mūchau bah apār",
      "translation_ru": "Ты высочайший, великий, безмерный и бесконечный."
    },
    {
      "index": 15,
      "verse_id": 42078,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਿਮਰਤ ਨਾਨਕ ਤਰੇ ਸਾਰ ॥੪॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "simrat Nānak tarē sār",
      "translation_ru": "Созерцая Тебя, Нанак переправляется через сущность этого мира."
    },
    {
      "index": 16,
      "verse_id": 42079,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Mālī Gauṛā mahalā 5",
      "translation_ru": "Мали Гаура, Пятый Махала."
    },
    {
      "index": 17,
      "verse_id": 42080,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਇਹੀ ਹਮਾਰੈ ਸਫਲ ਕਾਜ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ihī hamārē safal kāj",
      "translation_ru": "Это, прибежище у святых, для меня делает успешными все мои стремления."
    },
    {
      "index": 18,
      "verse_id": 42081,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪੁਨੇ ਦਾਸ ਕਉ ਲੇਹੁ ਨਿਵਾਜਿ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apunē dās kau lēhu nivāj",
      "translation_ru": "О Господь, прояви милость к Своему слуге Нанаку и даруй ему прибежище у святых."
    },
    {
      "index": 19,
      "verse_id": 42082,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਚਰਨ ਸੰਤਹ ਮਾਥ ਮੋਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "charaṇ santah māth mor",
      "translation_ru": "О Господь, пусть мой лоб остаётся у стоп святых."
    },
    {
      "index": 20,
      "verse_id": 42083,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨੈਨਿ ਦਰਸੁ ਪੇਖਉ ਨਿਸਿ ਭੋਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nēn daras pēkhau nis bhor",
      "translation_ru": "Пусть моими глазами я день и ночь созерцаю даршан святых."
    },
    {
      "index": 21,
      "verse_id": 42084,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਸਤ ਹਮਰੇ ਸੰਤ ਟਹਲ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "hast hamrē sant ṭahal",
      "translation_ru": "Пусть мои руки служат святым."
    },
    {
      "index": 22,
      "verse_id": 42085,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਾਨ ਮਨੁ ਧਨੁ ਸੰਤ ਬਹਲ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prān man dhan sant bahal",
      "translation_ru": "Пусть моя жизнь, мой ум и моё богатство будут отданы святым."
    },
    {
      "index": 23,
      "verse_id": 42086,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਸੰਗਿ ਮੇਰੇ ਮਨ ਕੀ ਪ੍ਰੀਤਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santsang mērē man kī prīt",
      "translation_ru": "О Господь, сделай так, чтобы любовь моего ума к святым всегда сохранялась."
    },
    {
      "index": 24,
      "verse_id": 42087,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਗੁਨ ਬਸਹਿ ਮੇਰੈ ਚੀਤਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant gun baseh mērē chīt",
      "translation_ru": "Пусть достоинства святых пребывают в моём сознании."
    },
    {
      "index": 25,
      "verse_id": 42088,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਆਗਿਆ ਮਨਹਿ ਮੀਠ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant āgiā maneh mīṭh",
      "translation_ru": "Пусть повеление святых кажется мне сладким в сердце."
    },
    {
      "index": 26,
      "verse_id": 42089,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੇਰਾ ਕਮਲੁ ਬਿਗਸੈ ਸੰਤ ਡੀਠ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mērā kamal bigsē sant ḍīṭh",
      "translation_ru": "Пусть при виде святых лотос моего сердца расцветает."
    },
    {
      "index": 27,
      "verse_id": 42090,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਸੰਗਿ ਮੇਰਾ ਹੋਇ ਨਿਵਾਸੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santsang mērā hōē nivās",
      "translation_ru": "О Господь, сделай так, чтобы моё пребывание было среди святых."
    },
    {
      "index": 28,
      "verse_id": 42091,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਨ ਕੀ ਮੋਹਿ ਬਹੁਤੁ ਪਿਆਸ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santan kī moh bahut piās",
      "translation_ru": "Пусть во мне пребывает сильная жажда даршана святых."
    },
    {
      "index": 29,
      "verse_id": 42092,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਬਚਨ ਮੇਰੇ ਮਨਹਿ ਮੰਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant bachan mērē maneh mant",
      "translation_ru": "Пусть слова святых как мантры пребывают в моём уме."
    },
    {
      "index": 30,
      "verse_id": 42093,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਮੇਰੇ ਬਿਖੈ ਹੰਤ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant prasād mērē bikhē hant",
      "translation_ru": "Пусть по милости святых все мои пороки будут уничтожены."
    },
    {
      "index": 31,
      "verse_id": 42094,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੁਕਤਿ ਜੁਗਤਿ ਏਹਾ ਨਿਧਾਨ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mukt jugat ēhā nidhān",
      "translation_ru": "Общество святых для меня является всеми сокровищами, и общение со святыми есть способ получить освобождение от пороков."
    },
    {
      "index": 32,
      "verse_id": 42095,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭ ਦਇਆਲ ਮੋਹਿ ਦੇਵਹੁ ਦਾਨ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh daiāl moh dēvah dān",
      "translation_ru": "О милосердный Господь, даруй мне этот дар общества святых."
    },
    {
      "index": 33,
      "verse_id": 42096,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭ ਦਇਆ ਧਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak kau prabh daiā dhār",
      "translation_ru": "О Господь, прояви милость к Нанаку."
    },
    {
      "index": 34,
      "verse_id": 42097,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਚਰਨ ਸੰਤਨ ਕੇ ਮੇਰੇ ਰਿਦੇ ਮਝਾਰਿ ॥੪॥੪॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "charaṇ santan kē mērē ridē majhār",
      "translation_ru": "Пусть стопы святых пребывают в сердце меня, Нанака."
    },
    {
      "index": 35,
      "verse_id": 42098,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Mālī Gauṛā mahalā 5",
      "translation_ru": "Мали Гаура, Пятый Махала."
    },
    {
      "index": 36,
      "verse_id": 42099,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਭ ਕੈ ਸੰਗੀ ਨਾਹੀ ਦੂਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sabh kē sangī nāhī dūr",
      "translation_ru": "Господь пребывает со всеми живыми существами и не далёк ни от кого."
    },
    {
      "index": 37,
      "verse_id": 42100,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਹਾਜਰਾ ਹਜੂਰਿ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "karan karāvan hājrā hajūr",
      "translation_ru": "Он Сам способен всё совершать и побуждать существ к действию; Он присутствует повсюду."
    },
    {
      "index": 38,
      "verse_id": 42101,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੁਨਤ ਜੀਓ ਜਾਸੁ ਨਾਮੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sunat jīo jās nām",
      "translation_ru": "Слушая имя того Господа, человек получает духовную жизнь."
    },
    {
      "index": 39,
      "verse_id": 42102,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦੁਖ ਬਿਨਸੇ ਸੁਖ ਕੀਓ ਬਿਸ੍ਰਾਮੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dukh binsē sukh kīo bisrām",
      "translation_ru": "Все страдания исчезают, и покой приходит поселиться в сердце."
    },
    {
      "index": 40,
      "verse_id": 42103,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਨਿਧਿ ਹਰਿ ਹਰਿ ਹਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagal nidh har har harē",
      "translation_ru": "Все сокровища находятся у того Параматмы, Хари."
    },
    {
      "index": 41,
      "verse_id": 42104,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੁਨਿ ਜਨ ਤਾ ਕੀ ਸੇਵ ਕਰੇ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mun jan tā kī sēv karē",
      "translation_ru": "Все мудрецы и отшельники совершают преданное служение Ему."
    },
    {
      "index": 42,
      "verse_id": 42105,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਾ ਕੈ ਘਰਿ ਸਗਲੇ ਸਮਾਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jā kē ghar saglē samāh",
      "translation_ru": "В доме того милостивого Господа пребывают все сокровища."
    },
    {
      "index": 43,
      "verse_id": 42106,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਸ ਤੇ ਬਿਰਥਾ ਕੋਇ ਨਾਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jis tē birthā kōē nāh",
      "translation_ru": "От Его двери ни одно существо не уходит пустым."
    },
    {
      "index": 44,
      "verse_id": 42107,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੀਅ ਜੰਤ੍ਰ ਕਰੇ ਪ੍ਰਤਿਪਾਲ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jīa jantar karē pratipāl",
      "translation_ru": "Он поддерживает и питает всех живых существ."
    },
    {
      "index": 45,
      "verse_id": 42108,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਦਾ ਸਦਾ ਸੇਵਹੁ ਕਿਰਪਾਲ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sadā sadā sēvahu kirpāl",
      "translation_ru": "Всегда, всегда совершайте преданное служение этому милостивому Господу."
    },
    {
      "index": 46,
      "verse_id": 42109,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਦਾ ਧਰਮੁ ਜਾ ਕੈ ਦੀਬਾਣਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sadā dharam jā kē dībāṇ",
      "translation_ru": "В Его суде всегда царит справедливость."
    },
    {
      "index": 47,
      "verse_id": 42110,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੇਮੁਹਤਾਜ ਨਹੀ ਕਿਛੁ ਕਾਣਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bēmuhatāj nahī kichh kāṇ",
      "translation_ru": "Он независим, Ему не нужна ничья поддержка."
    },
    {
      "index": 48,
      "verse_id": 42111,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਭ ਕਿਛੁ ਕਰਨਾ ਆਪਨ ਆਪਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sabh kichh karnā āpan āp",
      "translation_ru": "Он Сам способен совершать всё."
    },
    {
      "index": 49,
      "verse_id": 42112,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰੇ ਮਨ ਮੇਰੇ ਤੂ ਤਾ ਕਉ ਜਾਪਿ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rē man mērē tū tā kau jāp",
      "translation_ru": "О мой ум, повторяй имя этого Господа."
    },
    {
      "index": 50,
      "verse_id": 42113,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧਸੰਗਤਿ ਕਉ ਹਉ ਬਲਿਹਾਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhsangat kau hau balihār",
      "translation_ru": "Я приношу себя в жертву обществу Гуру."
    },
    {
      "index": 51,
      "verse_id": 42114,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਾਸੁ ਮਿਲਿ ਹੋਵੈ ਉਧਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jās mil hōvē udhār",
      "translation_ru": "Встретившись с ним, человек получает Имя Параматмы и переправляется через мировой океан."
    },
    {
      "index": 52,
      "verse_id": 42115,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮ ਸੰਗਿ ਮਨ ਤਨਹਿ ਰਾਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām sang man taneh rāt",
      "translation_ru": "Тот, кому Господь дарует дар Имени через Гуру, остаётся окрашенным Именем; Имя пребывает в его уме и теле."
    },
    {
      "index": 53,
      "verse_id": 42116,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭਿ ਕਰੀ ਦਾਤਿ ॥੪॥੫॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak kau prabh karī dāt",
      "translation_ru": "Господь даровал Нанаку этот дар."
    },
    {
      "index": 54,
      "verse_id": 42117,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ਦੁਪਦੇ",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Mālī Gauṛā mahalā 5 dupadē",
      "translation_ru": "Мали Гаура, Пятый Махала, двустишия."
    },
    {
      "index": 55,
      "verse_id": 42118,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ik oankār satgur prasād",
      "translation_ru": "Один Эконкар, по милости Сатгуру."
    },
    {
      "index": 56,
      "verse_id": 42119,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਸਮਰਥ ਕੀ ਸਰਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har samrath kī sarnā",
      "translation_ru": "Я пришёл под прибежище того Параматмы, который является обладателем всех сил."
    },
    {
      "index": 57,
      "verse_id": 42120,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਧਨੁ ਰਾਸਿ ਮੇਰੀ ਪ੍ਰਭ ਏਕ ਕਾਰਨ ਕਰਨਾ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jīo piṇḍ dhan rās mērī prabh ēk kāran karnā",
      "translation_ru": "Моя жизнь, моё тело, моё богатство, весь мой капитал — всё это тот единый Господь, который является корнем всего мира."
    },
    {
      "index": 58,
      "verse_id": 42121,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਦਾ ਸੁਖੁ ਪਾਈਐ ਜੀਵਣੈ ਕਾ ਮੂਲੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "simar simar sadā sukh pāīē jīvaṇē kā mūl",
      "translation_ru": "Снова и снова вспоминая Имя Параматмы, человек всегда получает духовное блаженство; Имя Хари — опора жизни."
    },
    {
      "index": 59,
      "verse_id": 42122,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਵਿ ਰਹਿਆ ਸਰਬਤ ਠਾਈ ਸੂਖਮੋ ਅਸਥੂਲ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rav rahiā sarbat ṭhāī sūkhamo asthūl",
      "translation_ru": "Во всех видимых и невидимых вещах, во всех местах присутствует один Параматма."
    }
  ]
}
