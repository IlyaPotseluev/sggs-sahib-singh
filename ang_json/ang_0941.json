{
  "ang": 941,
  "line_count": 54,
  "lines": [
    {
      "index": 1,
      "verse_id": 40108,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋ ਬੂਝੈ ਜਿਸੁ ਆਪਿ ਬੁਝਾਏ ਗੁਰ ਕੈ ਸਬਦਿ ਸੁ ਮੁਕਤੁ ਭਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "so būjhē jis āp bujhāe gur kē sabad so mukat bhēā",
      "translation_ru": "Понимает тот, кому Он сам даёт понять; через Шабд Гуру он становится свободным."
    },
    {
      "index": 2,
      "verse_id": 40109,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਤਾਰੇ ਤਾਰਣਹਾਰਾ ਹਉਮੈ ਦੂਜਾ ਪਰਹਰਿਆ ॥੨੫॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak tāre tāraṇhārā haumē dūjā parhariā",
      "translation_ru": "Нанак: Спасающий сам переправляет; Хоумэ и двойственность тогда отбрасываются."
    },
    {
      "index": 3,
      "verse_id": 40110,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨਮੁਖਿ ਭੂਲੈ ਜਮ ਕੀ ਕਾਣਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "manmukh bhūlē jam kī kāṇ",
      "translation_ru": "Тот, кто идёт за своим умом, сбивается с верного пути и становится подвластным Джаму."
    },
    {
      "index": 4,
      "verse_id": 40111,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਰ ਘਰੁ ਜੋਹੈ ਹਾਣੇ ਹਾਣਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "par ghar johē hāṇe hāṇ",
      "translation_ru": "Он засматривается на чужой дом, и в этом получает только ущерб за ущербом."
    },
    {
      "index": 5,
      "verse_id": 40112,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨਮੁਖਿ ਭਰਮਿ ਭਵੈ ਬੇਬਾਣਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "manmukh bharam bhavē bebāṇ",
      "translation_ru": "Манмукх, пребывая в заблуждении, будто блуждает в лесу."
    },
    {
      "index": 6,
      "verse_id": 40113,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਵੇਮਾਰਗਿ ਮੂਸੈ ਮੰਤ੍ਰਿ ਮਸਾਣਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "vē-mārag mūsē mantra masāṇ",
      "translation_ru": "Сойдя на неверный путь, он оказывается обманутым, как человек, читающий мантры на месте кремации и увлечённый дурным направлением."
    },
    {
      "index": 7,
      "verse_id": 40114,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਬਦੁ ਨ ਚੀਨੈ ਲਵੈ ਕੁਬਾਣਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sabad na chīnē lavē kubāṇ",
      "translation_ru": "Он не распознаёт Шабд Гуру, не ценит его и произносит дурные слова."
    },
    {
      "index": 8,
      "verse_id": 40115,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਸਾਚਿ ਰਤੇ ਸੁਖੁ ਜਾਣਿ ॥੨੬॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak sāch rate sukh jāṇ",
      "translation_ru": "Нанак: знай, что покой обрёл тот, кто окрашен в Истинного Господа."
    },
    {
      "index": 9,
      "verse_id": 40116,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੇ ਕਾ ਭਉ ਪਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sāche kā bhau pāvē",
      "translation_ru": "Гурмукх утверждает в сердце благоговейный страх перед Истинным Господом."
    },
    {
      "index": 10,
      "verse_id": 40117,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਬਾਣੀ ਅਘੜੁ ਘੜਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh bāṇī aghaṛ ghaṛāvē",
      "translation_ru": "Через Бани Гуру гурмукх приводит неукрощённый ум в должную форму."
    },
    {
      "index": 11,
      "verse_id": 40118,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਨਿਰਮਲ ਹਰਿ ਗੁਣ ਗਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh nirmal har guṇ gāvē",
      "translation_ru": "Гурмукх воспевает славу чистого Господа."
    },
    {
      "index": 12,
      "verse_id": 40119,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਵਿਤ੍ਰੁ ਪਰਮ ਪਦੁ ਪਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh pavitar param pad pāvē",
      "translation_ru": "Так он достигает чистого и высшего духовного состояния."
    },
    {
      "index": 13,
      "verse_id": 40120,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਰੋਮਿ ਰੋਮਿ ਹਰਿ ਧਿਆਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh rom rom har dhiāvē",
      "translation_ru": "Гурмукх всем телом и всей душой помнит Господа."
    },
    {
      "index": 14,
      "verse_id": 40121,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਾਚਿ ਸਮਾਵੈ ॥੨੭॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak gurmukh sāch samāvē",
      "translation_ru": "Нанак: через преданность гурмукх остаётся слитым с вечно пребывающим Господом."
    },
    {
      "index": 15,
      "verse_id": 40122,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਬੇਦ ਬੀਚਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh parchē bed bīchārī",
      "translation_ru": "Тот, кто обретает глубокую связь с Гуру, становится словно знатоком Вед и уже не нуждается в них."
    },
    {
      "index": 16,
      "verse_id": 40123,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਤਰੀਐ ਤਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh parchē tarīē tārī",
      "translation_ru": "Через глубокую связь с Гуру переправляются через океан мира."
    },
    {
      "index": 17,
      "verse_id": 40124,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਸੁ ਸਬਦਿ ਗਿਆਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh parchē so sabad giānī",
      "translation_ru": "Через такую связь и через Гур-Шабд человек становится познавшим Господа."
    },
    {
      "index": 18,
      "verse_id": 40125,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਅੰਤਰ ਬਿਧਿ ਜਾਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh parchē antar bidh jānī",
      "translation_ru": "Он начинает понимать внутреннее состояние и внутренний порядок."
    },
    {
      "index": 19,
      "verse_id": 40126,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਈਐ ਅਲਖ ਅਪਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh pāīai alakh apār",
      "translation_ru": "Обратившись к Гуру, обретают невидимого и бесконечного Господа."
    },
    {
      "index": 20,
      "verse_id": 40127,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਮੁਕਤਿ ਦੁਆਰੁ ॥੨੮॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak gurmukh mukat duār",
      "translation_ru": "Нанак: только через Гуру находится дверь освобождения от Хоумэ."
    },
    {
      "index": 21,
      "verse_id": 40128,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਅਕਥੁ ਕਥੈ ਬੀਚਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh akath kathē bīchār",
      "translation_ru": "Идущий путём Гуру через данное Гуру размышление воспевает Того, чей истинный облик невозможно выразить."
    },
    {
      "index": 22,
      "verse_id": 40129,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਨਿਬਹੈ ਸਪਰਵਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh nibhē saparvār",
      "translation_ru": "Такой гурмукх, даже живя в семье, успешно проходит игру жизни."
    },
    {
      "index": 23,
      "verse_id": 40130,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਜਪੀਐ ਅੰਤਰਿ ਪਿਆਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh japīai antar piār",
      "translation_ru": "Только обратившись к Гуру, можно с любовью в сердце повторять и помнить Господа."
    },
    {
      "index": 24,
      "verse_id": 40131,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਈਐ ਸਬਦਿ ਅਚਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh pāīai sabad achār",
      "translation_ru": "Через Гур-Шабд и высокий образ жизни обретается Господь."
    },
    {
      "index": 25,
      "verse_id": 40132,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਬਦਿ ਭੇਦਿ ਜਾਣੈ ਜਾਣਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sabad bhed jāṇē jāṇāī",
      "translation_ru": "Пронзив свой ум Шабдом Гуру, он распознаёт Господа и помогает другим распознать Его."
    },
    {
      "index": 26,
      "verse_id": 40133,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਹਉਮੈ ਜਾਲਿ ਸਮਾਈ ॥੨੯॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak haumē jāl samāī",
      "translation_ru": "Нанак: гурмукх сжигает свою Хоумэ, эгоистичность, и остаётся слитым с Господом."
    },
    {
      "index": 27,
      "verse_id": 40134,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਧਰਤੀ ਸਾਚੈ ਸਾਜੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh dhartī sāchē sājī",
      "translation_ru": "Истинный Господь создал землю ради появления гурмукха."
    },
    {
      "index": 28,
      "verse_id": 40135,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਸ ਮਹਿ ਓਪਤਿ ਖਪਤਿ ਸੁ ਬਾਜੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tis mah opat khapat so bājī",
      "translation_ru": "На этой земле рождение и уничтожение являются игрой для развития состояния гурмукха."
    },
    {
      "index": 29,
      "verse_id": 40136,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਰਪੈ ਰੰਗੁ ਲਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur kē sabad rapē raṅg lāi",
      "translation_ru": "Когда человек через Шабд Гуру соединяет любовь с Господом, он окрашивается в Его цвет."
    },
    {
      "index": 30,
      "verse_id": 40137,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਚਿ ਰਤਉ ਪਤਿ ਸਿਉ ਘਰਿ ਜਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sāch rato pat siu ghar jāi",
      "translation_ru": "Окрашенный Истинным, гурмукх с честью достигает своего дома."
    },
    {
      "index": 31,
      "verse_id": 40138,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਚ ਸਬਦ ਬਿਨੁ ਪਤਿ ਨਹੀ ਪਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sāch sabad bin pat nahī pāvē",
      "translation_ru": "Без Истинного Шабда человек не может обрести честь."
    },
    {
      "index": 32,
      "verse_id": 40139,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਬਿਨੁ ਨਾਵੈ ਕਿਉ ਸਾਚਿ ਸਮਾਵੈ ॥੩੦॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak bin nāvē kiu sāch samāvē",
      "translation_ru": "Нанак: без Имени как человек может слиться с Истинным Господом? Не может."
    },
    {
      "index": 33,
      "verse_id": 40140,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਅਸਟ ਸਿਧੀ ਸਭਿ ਬੁਧੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh asaṭ sidhī sabh budhī",
      "translation_ru": "Идти путём Гуру — это и есть обретение всех восьми сиддхи и всех разумений."
    },
    {
      "index": 34,
      "verse_id": 40141,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਭਵਜਲੁ ਤਰੀਐ ਸਚ ਸੁਧੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh bhavjal tarīai sach sudhī",
      "translation_ru": "Обратившись к Гуру, переправляются через океан мира и обретают прекрасное понимание Истинного."
    },
    {
      "index": 35,
      "verse_id": 40142,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਸਰ ਅਪਸਰ ਬਿਧਿ ਜਾਣੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh sar apsar bidh jāṇē",
      "translation_ru": "Идущий путём Гуру понимает состояние благого и неблагого времени."
    },
    {
      "index": 36,
      "verse_id": 40143,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਵਿਰਤਿ ਨਰਵਿਰਤਿ ਪਛਾਣੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh parvirat narvirat pachhāṇē",
      "translation_ru": "Он распознаёт, что следует принять и что следует оставить."
    },
    {
      "index": 37,
      "verse_id": 40144,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਤਾਰੇ ਪਾਰਿ ਉਤਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh tāre pār utāre",
      "translation_ru": "Гурмукх переправляет и других через океан мира к дальнему берегу."
    },
    {
      "index": 38,
      "verse_id": 40145,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਬਦਿ ਨਿਸਤਾਰੇ ॥੩੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak gurmukh sabad nistāre",
      "translation_ru": "Нанак: тот, кто идёт по наставлению Гуру, через Шабд спасает и других."
    },
    {
      "index": 39,
      "verse_id": 40146,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮੇ ਰਾਤੇ ਹਉਮੈ ਜਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nāme rāte haumē jāi",
      "translation_ru": "У того, кто окрашен в Имя Господа, исчезает Хоумэ."
    },
    {
      "index": 40,
      "verse_id": 40147,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਚਿ ਰਹੇ ਸਮਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate sach rahe samāi",
      "translation_ru": "Те, кто окрашен в Имя, пребывают слитыми с Господом."
    },
    {
      "index": 41,
      "verse_id": 40148,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਜੋਗ ਜੁਗਤਿ ਬੀਚਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate jog jugat bīchār",
      "translation_ru": "Только окрашенные в Имя получают подлинный способ йоги и верное размышление."
    },
    {
      "index": 42,
      "verse_id": 40149,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਪਾਵਹਿ ਮੋਖ ਦੁਆਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate pāvah mokh duār",
      "translation_ru": "Окрашенные в Имя находят дверь освобождения от Хоумэ."
    },
    {
      "index": 43,
      "verse_id": 40150,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਤ੍ਰਿਭਵਣ ਸੋਝੀ ਹੋਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate tribhavaṇ sojhī hoi",
      "translation_ru": "Окрашенные в Имя обретают понимание трёх миров: вместо малой отдельности им видна родственная связь всего через Бога."
    },
    {
      "index": 44,
      "verse_id": 40151,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਰਤੇ ਸਦਾ ਸੁਖੁ ਹੋਇ ॥੩੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak nām rate sadā sukh hoi",
      "translation_ru": "Нанак: окрашенный в Имя Господа обретает вечно устойчивый покой."
    },
    {
      "index": 45,
      "verse_id": 40152,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਿਧ ਗੋਸਟਿ ਹੋਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate sidh gosṭ hoi",
      "translation_ru": "Только через окрашенность в Имя происходит встреча с совершенным Господом."
    },
    {
      "index": 46,
      "verse_id": 40153,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਦਾ ਤਪੁ ਹੋਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate sadā tap hoi",
      "translation_ru": "Пребывать окрашенным в Имя Господа — это вечное благодетельное подвижничество."
    },
    {
      "index": 47,
      "verse_id": 40154,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਚੁ ਕਰਣੀ ਸਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate sach karṇī sār",
      "translation_ru": "Привязанность к Имени — это истинное и высшее деяние."
    },
    {
      "index": 48,
      "verse_id": 40155,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮਿ ਰਤੇ ਗੁਣ ਗਿਆਨ ਬੀਚਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām rate guṇ giān bīchār",
      "translation_ru": "Только оставаясь окрашенным в Имя, человек узнаёт качества Господа и вступает с Ним в связь."
    },
    {
      "index": 49,
      "verse_id": 40156,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਬੋਲੈ ਸਭੁ ਵੇਕਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin nāvē bolē sabh vekār",
      "translation_ru": "Без Имени Господа всё, что говорит человек, бесплодно."
    },
    {
      "index": 50,
      "verse_id": 40157,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਰਤੇ ਤਿਨ ਕਉ ਜੈਕਾਰੁ ॥੩੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Nānak nām rate tin kau jēkār",
      "translation_ru": "Нанак: тем, кто окрашен в Имя, наше почтение и прославление."
    },
    {
      "index": 51,
      "verse_id": 40158,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੂਰੇ ਗੁਰ ਤੇ ਨਾਮੁ ਪਾਇਆ ਜਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pūre gur te nām pāiā jāi",
      "translation_ru": "Имя Господа обретается от совершенного Гуру."
    },
    {
      "index": 52,
      "verse_id": 40159,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੋਗ ਜੁਗਤਿ ਸਚਿ ਰਹੈ ਸਮਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jog jugat sach rahē samāi",
      "translation_ru": "Быть слитым с Истинным Господом — это и есть подлинный способ йоги."
    },
    {
      "index": 53,
      "verse_id": 40160,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਾਰਹ ਮਹਿ ਜੋਗੀ ਭਰਮਾਏ ਸੰਨਿਆਸੀ ਛਿਅ ਚਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bārah mah jogī bharmāe sanniāsī chhia chār",
      "translation_ru": "Йоги заблуждаются в своих двенадцати течениях, а санньяси — в своих десяти течениях и различных средствах."
    },
    {
      "index": 54,
      "verse_id": 40161,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਜੋ ਮਰਿ ਜੀਵੈ ਸੋ ਪਾਏ ਮੋਖ ਦੁਆਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur kē sabad jo mar jīvē so pāe mokh duār",
      "translation_ru": "Тот, кто через Шабд Сатгуру умирает для майи и живёт духовно, находит дверь освобождения от Хоумэ."
    }
  ]
}
