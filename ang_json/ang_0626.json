{
  "ang": 626,
  "line_count": 60,
  "lines": [
    {
      "index": 1,
      "verse_id": 27094,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੁਖ ਸਾਗਰੁ ਗੁਰੁ ਪਾਇਆ ॥ ਤਾ ਸਹਸਾ ਸਗਲ ਮਿਟਾਇਆ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sukh sāgar gur pāiā. tā sahsā sagal miṭāiā. ||1||",
      "translation_ru": "Когда был обретён Гуру, океан счастья, тогда весь страх и сомнение исчезли."
    },
    {
      "index": 2,
      "verse_id": 27095,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਕੀ ਵਡਿਆਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har ke nām kī vaḍiāī.",
      "translation_ru": "Величие — в восхвалении Имени Бога."
    },
    {
      "index": 3,
      "verse_id": 27096,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਠ ਪਹਰ ਗੁਣ ਗਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "āṭh pahar guṇ gāī.",
      "translation_ru": "Все восемь страж дня и ночи воспевай достоинства Бога."
    },
    {
      "index": 4,
      "verse_id": 27097,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਪਾਈ ॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūre te pāī. rahāu.",
      "translation_ru": "Этот дар обретается только от совершенного Гуру. Пауза."
    },
    {
      "index": 5,
      "verse_id": 27098,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭ ਕੀ ਅਕਥ ਕਹਾਣੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh kī akath kahāṇī.",
      "translation_ru": "Повествование о сущности Господа невозможно полностью выразить словами."
    },
    {
      "index": 6,
      "verse_id": 27099,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਨ ਬੋਲਹਿ ਅੰਮ੍ਰਿਤ ਬਾਣੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jan bolah amrit bāṇī.",
      "translation_ru": "Слуги Господа произносят Бани хвалы, дающую духовную жизнь."
    },
    {
      "index": 7,
      "verse_id": 27100,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਦਾਸ ਵਖਾਣੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak dās vakhāṇī.",
      "translation_ru": "Нанак говорит: слуги Господа произносят эту Бани."
    },
    {
      "index": 8,
      "verse_id": 27101,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਜਾਣੀ ॥੨॥੨॥੬੬॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūre te jāṇī. ||2||2||66||",
      "translation_ru": "Они познали это понимание от совершенного Гуру."
    },
    {
      "index": 9,
      "verse_id": 27102,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahlā 5.",
      "translation_ru": "Соратх, Пятый Махла."
    },
    {
      "index": 10,
      "verse_id": 27103,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਗੈ ਸੁਖੁ ਗੁਰਿ ਦੀਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "āgē sukh gur dīā.",
      "translation_ru": "Гуру даровал покой и на пути будущей жизни."
    },
    {
      "index": 11,
      "verse_id": 27104,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਛੈ ਕੁਸਲ ਖੇਮ ਗੁਰਿ ਕੀਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāchhē kusal khem gur kīā.",
      "translation_ru": "И в прошедшем, в этой жизни, Гуру дал мир, благополучие и радость."
    },
    {
      "index": 12,
      "verse_id": 27105,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਸੁਖ ਪਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sarab nidhān sukh pāiā.",
      "translation_ru": "Так человек обрёл все духовные сокровища и всё счастье."
    },
    {
      "index": 13,
      "verse_id": 27106,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰੁ ਅਪੁਨਾ ਰਿਦੈ ਧਿਆਇਆ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur apunā ridē dhiāiā. ||1||",
      "translation_ru": "Потому что он поселил своего Гуру в сердце."
    },
    {
      "index": 14,
      "verse_id": 27107,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪਨੇ ਸਤਿਗੁਰ ਕੀ ਵਡਿਆਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apne satigur kī vaḍiāī.",
      "translation_ru": "Таково величие и высокая духовная щедрость своего Сатгуру."
    },
    {
      "index": 15,
      "verse_id": 27108,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਇਛੇ ਫਲ ਪਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man ichhe phal pāī.",
      "translation_ru": "Тот, кто приходит под защиту Гуру, получает желанные плоды сердца."
    },
    {
      "index": 16,
      "verse_id": 27109,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਹੁ ਦਿਨੁ ਦਿਨੁ ਚੜੈ ਸਵਾਈ ॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santah din din chaṛē savāī. rahāu.",
      "translation_ru": "О святые, щедрость Гуру день ото дня возрастает. Пауза."
    },
    {
      "index": 17,
      "verse_id": 27110,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੀਅ ਜੰਤ ਸਭਿ ਭਏ ਦਇਆਲਾ ਪ੍ਰਭਿ ਅਪਨੇ ਕਰਿ ਦੀਨੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jīa jant sabh bhae daiālā prabh apne kar dīne.",
      "translation_ru": "Все существа, пришедшие под защиту Гуру, становятся исполненными милости, и Господь делает их своими."
    },
    {
      "index": 18,
      "verse_id": 27111,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਹਜ ਸੁਭਾਇ ਮਿਲੇ ਗੋਪਾਲਾ ਨਾਨਕ ਸਾਚਿ ਪਤੀਨੇ ॥੨॥੩॥੬੭॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sahaj subhāe mile gopālā nānak sāch patīne. ||2||3||67||",
      "translation_ru": "Нанак говорит: благодаря духовной устойчивости и любви они встречают Господа-Хранителя мира и остаются опьянёнными Истинным."
    },
    {
      "index": 19,
      "verse_id": 27112,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahlā 5.",
      "translation_ru": "Соратх, Пятый Махла."
    },
    {
      "index": 20,
      "verse_id": 27113,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਰਖਵਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur kā sabad rakhvāre.",
      "translation_ru": "Слово Гуру — наш защитник."
    },
    {
      "index": 21,
      "verse_id": 27114,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਚਉਕੀ ਚਉਗਿਰਦ ਹਮਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "chaukī chaugirad hamāre.",
      "translation_ru": "Это Слово стоит стражей вокруг нас со всех сторон."
    },
    {
      "index": 22,
      "verse_id": 27115,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮ ਨਾਮਿ ਮਨੁ ਲਾਗਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rām nām man lāgā.",
      "translation_ru": "Когда ум соединяется с Именем Бога,"
    },
    {
      "index": 23,
      "verse_id": 27116,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਮੁ ਲਜਾਇ ਕਰਿ ਭਾਗਾ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jam lajāe kar bhāgā. ||1||",
      "translation_ru": "даже Джам, посрамлённый, убегает от такого человека."
    },
    {
      "index": 24,
      "verse_id": 27117,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭ ਜੀ ਤੂ ਮੇਰੋ ਸੁਖਦਾਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh jī tū mero sukhdātā.",
      "translation_ru": "О Господь, для меня только Ты — даритель счастья."
    },
    {
      "index": 25,
      "verse_id": 27118,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਕਰੇ ਮਨੁ ਨਿਰਮਲੁ ਪੂਰਨ ਪੁਰਖੁ ਬਿਧਾਤਾ ॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bandhan kāṭ kare man nirmal pūran purakh bidhātā. rahāu.",
      "translation_ru": "Всепроникающий Творец отсекает узы привязанности и очищает ум. Пауза."
    },
    {
      "index": 26,
      "verse_id": 27119,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭੁ ਅਬਿਨਾਸੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak prabh abināsī.",
      "translation_ru": "Нанак говорит: бессмертный Господь так щедр,"
    },
    {
      "index": 27,
      "verse_id": 27120,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਾ ਕੀ ਸੇਵ ਨ ਬਿਰਥੀ ਜਾਸੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tā kī sev na birthī jāsī.",
      "translation_ru": "что служение и преданность Ему никогда не проходят впустую."
    },
    {
      "index": 28,
      "verse_id": 27121,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਨਦ ਕਰਹਿ ਤੇਰੇ ਦਾਸਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "anad karah tere dāsā.",
      "translation_ru": "Твои слуги всегда наслаждаются духовной радостью."
    },
    {
      "index": 29,
      "verse_id": 27122,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਪਿ ਪੂਰਨ ਹੋਈ ਆਸਾ ॥੨॥੪॥੬੮॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jap pūran hoī āsā. ||2||4||68||",
      "translation_ru": "Повторяя Твоё Имя, они обретают исполнение всех сердечных желаний."
    },
    {
      "index": 30,
      "verse_id": 27123,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahlā 5.",
      "translation_ru": "Соратх, Пятый Махла."
    },
    {
      "index": 31,
      "verse_id": 27124,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਅਪੁਨੇ ਬਲਿਹਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur apune balihārī.",
      "translation_ru": "Я жертвую собой своему Гуру."
    },
    {
      "index": 32,
      "verse_id": 27125,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਨਿ ਪੂਰਨ ਪੈਜ ਸਵਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jin pūran pēj savārī.",
      "translation_ru": "Он полностью сохранил мою честь, даровав мне Имя Господа."
    },
    {
      "index": 33,
      "verse_id": 27126,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਚਿੰਦਿਆ ਫਲੁ ਪਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man chindiā phal pāiā.",
      "translation_ru": "Человек получает желанный плод сердца,"
    },
    {
      "index": 34,
      "verse_id": 27127,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭੁ ਅਪੁਨਾ ਸਦਾ ਧਿਆਇਆ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh apunā sadā dhiāiā. ||1||",
      "translation_ru": "если всегда медитирует на своего Господа."
    },
    {
      "index": 35,
      "verse_id": 27128,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਹੁ ਤਿਸੁ ਬਿਨੁ ਅਵਰੁ ਨ ਕੋਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santah tis bin avar na koī.",
      "translation_ru": "О святые, кроме этого Господа, нет другого защитника."
    },
    {
      "index": 36,
      "verse_id": 27129,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਣ ਕਾਰਣ ਪ੍ਰਭੁ ਸੋਈ ॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "karaṇ kāraṇ prabh soī. rahāu.",
      "translation_ru": "Только этот Господь — первооснова всего мира. Пауза."
    },
    {
      "index": 37,
      "verse_id": 27130,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭਿ ਅਪਨੈ ਵਰ ਦੀਨੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh apnē var dīne.",
      "translation_ru": "Любимый Господь даровал все благословения."
    },
    {
      "index": 38,
      "verse_id": 27131,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਜੀਅ ਵਸਿ ਕੀਨੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagal jīa vas kīne.",
      "translation_ru": "Он держит всех существ в своей власти."
    },
    {
      "index": 39,
      "verse_id": 27132,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਨ ਨਾਨਕ ਨਾਮੁ ਧਿਆਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jan nānak nām dhiāiā.",
      "translation_ru": "Слуга Нанак говорит: когда кто-либо медитирует на Имя Господа,"
    },
    {
      "index": 40,
      "verse_id": 27133,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਾ ਸਗਲੇ ਦੂਖ ਮਿਟਾਇਆ ॥੨॥੫॥੬੯॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tā sagle dūkh miṭāiā. ||2||5||69||",
      "translation_ru": "тогда все его страдания исчезают."
    },
    {
      "index": 41,
      "verse_id": 27134,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahlā 5.",
      "translation_ru": "Соратх, Пятый Махла."
    },
    {
      "index": 42,
      "verse_id": 27135,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਾਪੁ ਗਵਾਇਆ ਗੁਰਿ ਪੂਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tāp gavāiā gur pūre.",
      "translation_ru": "Совершенный Гуру устранил внутреннюю боль и страдание."
    },
    {
      "index": 43,
      "verse_id": 27136,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਵਾਜੇ ਅਨਹਦ ਤੂਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "vāje anahad tūre.",
      "translation_ru": "Внутри зазвучали непрерывные трубы духовной радости."
    },
    {
      "index": 44,
      "verse_id": 27137,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਰਬ ਕਲਿਆਣ ਪ੍ਰਭਿ ਕੀਨੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sarab kaliāṇ prabh kīne.",
      "translation_ru": "Господь даровал все виды счастья и благополучия."
    },
    {
      "index": 45,
      "verse_id": 27138,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਆਪਿ ਦੀਨੇ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kar kirpā āp dīne. ||1||",
      "translation_ru": "По своей милости Он сам всё это дал."
    },
    {
      "index": 46,
      "verse_id": 27139,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੇਦਨ ਸਤਿਗੁਰਿ ਆਪਿ ਗਵਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bedan satigur āp gavāī.",
      "translation_ru": "Сатгуру сам устранил всякую боль."
    },
    {
      "index": 47,
      "verse_id": 27140,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਿਖ ਸੰਤ ਸਭਿ ਸਰਸੇ ਹੋਏ ਹਰਿ ਹਰਿ ਨਾਮੁ ਧਿਆਈ ॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sikh sant sabh sarse hoe har har nām dhiāī. rahāu.",
      "translation_ru": "Все сикхи и святые, медитируя на Имя Бога, стали исполнены радости. Пауза."
    },
    {
      "index": 48,
      "verse_id": 27141,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੋ ਮੰਗਹਿ ਸੋ ਲੇਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jo mangah so levah.",
      "translation_ru": "Что бы святые ни просили у Твоих дверей, они это получают."
    },
    {
      "index": 49,
      "verse_id": 27142,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭ ਅਪਣਿਆ ਸੰਤਾ ਦੇਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh apṇiā santā devah.",
      "translation_ru": "О Господь, Ты сам даёшь всё своим святым."
    },
    {
      "index": 50,
      "verse_id": 27143,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਗੋਵਿਦੁ ਪ੍ਰਭਿ ਰਾਖਿਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har govid prabh rākhiā.",
      "translation_ru": "Господь сам защитил Харгобинда."
    },
    {
      "index": 51,
      "verse_id": 27144,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਨ ਨਾਨਕ ਸਾਚੁ ਸੁਭਾਖਿਆ ॥੨॥੬॥੭੦॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jan nānak sāch subhākhiā. ||2||6||70||",
      "translation_ru": "Слуга Нанак говорит: я произношу только Имя вечно Истинного Господа."
    },
    {
      "index": 52,
      "verse_id": 27145,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahlā 5.",
      "translation_ru": "Соратх, Пятый Махла."
    },
    {
      "index": 53,
      "verse_id": 27146,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਈ ਕਰਾਇ ਜੋ ਤੁਧੁ ਭਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soī karāe jo tudh bhāvē.",
      "translation_ru": "О Господь, заставляй меня делать только то, что Тебе угодно."
    },
    {
      "index": 54,
      "verse_id": 27147,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੋਹਿ ਸਿਆਣਪ ਕਛੂ ਨ ਆਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "moh siāṇap kachhū na āvē.",
      "translation_ru": "Мне не приходит никакая собственная мудрость."
    },
    {
      "index": 55,
      "verse_id": 27148,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਮ ਬਾਰਿਕ ਤਉ ਸਰਣਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ham bārik tau sarṇāī.",
      "translation_ru": "Мы — Твои дети и пришли под Твою защиту."
    },
    {
      "index": 56,
      "verse_id": 27149,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭਿ ਆਪੇ ਪੈਜ ਰਖਾਈ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh āpe pēj rakhāī. ||1||",
      "translation_ru": "Господь сам всегда сохраняет честь того, кто приходит под Его защиту."
    },
    {
      "index": 57,
      "verse_id": 27150,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੇਰਾ ਮਾਤ ਪਿਤਾ ਹਰਿ ਰਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "merā māt pitā har rāiā.",
      "translation_ru": "О Господь-Царь, Ты — моя мать и мой отец."
    },
    {
      "index": 58,
      "verse_id": 27151,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਤਿਪਾਲਣ ਲਾਗਾ ਕਰਂੀ ਤੇਰਾ ਕਰਾਇਆ ॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kar kirpā pratipālaṇ lāgā karī terā karāiā. rahāu.",
      "translation_ru": "По милости Ты сам заботишься обо мне; я делаю только то, что Ты заставляешь меня делать. Пауза."
    },
    {
      "index": 59,
      "verse_id": 27152,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੀਅ ਜੰਤ ਤੇਰੇ ਧਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jīa jant tere dhāre.",
      "translation_ru": "Все живые существа держатся на Твоей опоре."
    },
    {
      "index": 60,
      "verse_id": 27153,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭ ਡੋਰੀ ਹਾਥਿ ਤੁਮਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh ḍorī hāth tumāre.",
      "translation_ru": "О Господь, нить жизни находится в Твоей руке."
    }
  ]
}
