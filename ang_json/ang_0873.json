{
  "ang": 873,
  "line_count": 54,
  "lines": [
    {
      "index": 1,
      "verse_id": 37065,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੋਂਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "goṇḍ",
      "translation_ru": "Гонд."
    },
    {
      "index": 2,
      "verse_id": 37066,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧੰਨੁ ਗੁਪਾਲ ਧੰਨੁ ਗੁਰਦੇਵ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhann gupāl dhann gurdev",
      "translation_ru": "Благословен Гупал, Господь-хранитель земли; благословен Гурдев, Сатгуру."
    },
    {
      "index": 3,
      "verse_id": 37067,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧੰਨੁ ਅਨਾਦਿ ਭੂਖੇ ਕਵਲੁ ਟਹਕੇਵ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhann anād bhūkhey kaval ṭahkev",
      "translation_ru": "Благословенно зерно: от него сердце голодного человека расцветает, как цветок."
    },
    {
      "index": 4,
      "verse_id": 37068,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧਨੁ ਓਇ ਸੰਤ ਜਿਨ ਐਸੀ ਜਾਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhan oi sant jin aisī jānī",
      "translation_ru": "Благословенны те святые, которые поняли это."
    },
    {
      "index": 5,
      "verse_id": 37069,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਨ ਕਉ ਮਿਲਿਬੋ ਸਾਰਿੰਗਪਾਨੀ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tin kau milibo sāriṅgpānī",
      "translation_ru": "Им встречается Параматма, Господь с луком в руке."
    },
    {
      "index": 6,
      "verse_id": 37070,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਦਿ ਪੁਰਖ ਤੇ ਹੋਇ ਅਨਾਦਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ād purakh te hoi anād",
      "translation_ru": "Зерно рождается от Изначального Пуруша, от Параматмы."
    },
    {
      "index": 7,
      "verse_id": 37071,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਪੀਐ ਨਾਮੁ ਅੰਨ ਕੈ ਸਾਦਿ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "japīai nām ann kai sād",
      "translation_ru": "Имя Бога можно повторять, когда тело поддержано вкусом и силой пищи. Пауза."
    },
    {
      "index": 8,
      "verse_id": 37072,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਪੀਐ ਨਾਮੁ ਜਪੀਐ ਅੰਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "japīai nām japīai ann",
      "translation_ru": "Следует повторять Имя и также с любовью принимать зерно."
    },
    {
      "index": 9,
      "verse_id": 37073,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅੰਭੈ ਕੈ ਸੰਗਿ ਨੀਕਾ ਵੰਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ambhai kai saṅg nīkā vann",
      "translation_ru": "Посмотри, какой прекрасный вид получает зерно в соединении с водой."
    },
    {
      "index": 10,
      "verse_id": 37074,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅੰਨੈ ਬਾਹਰਿ ਜੋ ਨਰ ਹੋਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "annai bāhar jo nar hovahi",
      "translation_ru": "Те люди, которые отворачиваются от зерна,"
    },
    {
      "index": 11,
      "verse_id": 37075,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤੀਨਿ ਭਵਨ ਮਹਿ ਅਪਨੀ ਖੋਵਹਿ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tīn bhavan meh apnī khovahi",
      "translation_ru": "везде теряют собственную честь."
    },
    {
      "index": 12,
      "verse_id": 37076,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਛੋਡਹਿ ਅੰਨੁ ਕਰਹਿ ਪਾਖੰਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "chhoḍahi ann karahi pākhaṇḍ",
      "translation_ru": "Те, кто оставляет зерно и творит этот показной обман,"
    },
    {
      "index": 13,
      "verse_id": 37077,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾ ਸੋਹਾਗਨਿ ਨਾ ਓਹਿ ਰੰਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nā sohāgan nā ohi raṇḍ",
      "translation_ru": "подобны женщинам, которые ни замужние, ни вдовы."
    },
    {
      "index": 14,
      "verse_id": 37078,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਗ ਮਹਿ ਬਕਤੇ ਦੂਧਾਧਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jag meh bakte dūdhādhārī",
      "translation_ru": "В мире они объявляют: «Мы живём только на молоке»."
    },
    {
      "index": 15,
      "verse_id": 37079,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਪਤੀ ਖਾਵਹਿ ਵਟਿਕਾ ਸਾਰੀ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "guptī khāvahi vaṭikā sārī",
      "translation_ru": "Но тайком съедают целые лепёшки из риса и маша."
    },
    {
      "index": 16,
      "verse_id": 37080,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅੰਨੈ ਬਿਨਾ ਨ ਹੋਇ ਸੁਕਾਲੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "annai binā na hoi sukāl",
      "translation_ru": "Без зерна не бывает благополучного времени."
    },
    {
      "index": 17,
      "verse_id": 37081,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਜਿਐ ਅੰਨਿ ਨ ਮਿਲੈ ਗੁਪਾਲੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "taji-ai ann na milai gupāl",
      "translation_ru": "Оставив зерно, Гупала не встретить."
    },
    {
      "index": 18,
      "verse_id": 37082,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਹਮ ਐਸੇ ਜਾਨਿਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaho kabīr ham aise jāniā",
      "translation_ru": "Говорит Кабир: мы поняли это так."
    },
    {
      "index": 19,
      "verse_id": 37083,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧੰਨੁ ਅਨਾਦਿ ਠਾਕੁਰ ਮਨੁ ਮਾਨਿਆ ॥੪॥੮॥੧੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhann anād ṭhākur man māniā",
      "translation_ru": "Благословенно зерно; принимая его и совершая симран, наш ум соединяется с Господом."
    },
    {
      "index": 20,
      "verse_id": 37084,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਬਾਣੀ ਨਾਮਦੇਉ ਜੀ ਕੀ ਘਰੁ ੧",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rāg goṇḍ bāṇī nāmdev jī kī ghar 1",
      "translation_ru": "Раг Гонд, бани Намдев Джи, первый дом."
    },
    {
      "index": 21,
      "verse_id": 37085,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ik oankār satgur prasād",
      "translation_ru": "Единый Онкар; по милости Сатгуру."
    },
    {
      "index": 22,
      "verse_id": 37086,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਸੁਮੇਧ ਜਗਨੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "asumedh jagne",
      "translation_ru": "Даже если человек совершит жертвоприношения ашвамедха,"
    },
    {
      "index": 23,
      "verse_id": 37087,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤੁਲਾ ਪੁਰਖ ਦਾਨੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tulā purakh dāne",
      "translation_ru": "даст дары, равные весу собственного тела,"
    },
    {
      "index": 24,
      "verse_id": 37088,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਾਗ ਇਸਨਾਨੇ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prāg isnāne",
      "translation_ru": "и совершит омовения в Праяге и других тиртхах,"
    },
    {
      "index": 25,
      "verse_id": 37089,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਉ ਨ ਪੁਜਹਿ ਹਰਿ ਕੀਰਤਿ ਨਾਮਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tau na pujahi har kīrat nāmā",
      "translation_ru": "всё это не может сравниться с Именем и восхвалением Хари."
    },
    {
      "index": 26,
      "verse_id": 37090,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪੁਨੇ ਰਾਮਹਿ ਭਜੁ ਰੇ ਮਨ ਆਲਸੀਆ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apune rāmeh bhaj re man ālasīā",
      "translation_ru": "О ленивый мой ум, вспоминай своего возлюбленного Рама. Пауза."
    },
    {
      "index": 27,
      "verse_id": 37091,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਇਆ ਪਿੰਡੁ ਭਰਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gaiā piṇḍ bhartā",
      "translation_ru": "Даже если человек в Гае совершает подношение пинды предкам,"
    },
    {
      "index": 28,
      "verse_id": 37092,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਨਾਰਸਿ ਅਸਿ ਬਸਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "banāras as bastā",
      "translation_ru": "живёт у реки Аси возле Бенареса,"
    },
    {
      "index": 29,
      "verse_id": 37093,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੁਖਿ ਬੇਦ ਚਤੁਰ ਪੜਤਾ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mukh bed chatur paṛtā",
      "translation_ru": "и устами наизусть читает четыре Веды,"
    },
    {
      "index": 30,
      "verse_id": 37094,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਧਰਮ ਅਛਿਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagal dharam achhitā",
      "translation_ru": "даже если человек совершает все религиозные дела,"
    },
    {
      "index": 31,
      "verse_id": 37095,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਗਿਆਨ ਇੰਦ੍ਰੀ ਦ੍ਰਿੜਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur giān indrī driṛtā",
      "translation_ru": "получив наставление гуру, держит чувства под контролем,"
    },
    {
      "index": 32,
      "verse_id": 37096,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਖਟੁ ਕਰਮ ਸਹਿਤ ਰਹਤਾ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "khaṭ karam sahit rahtā",
      "translation_ru": "и постоянно исполняет все шесть брахманских обязанностей,"
    },
    {
      "index": 33,
      "verse_id": 37097,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਿਵਾ ਸਕਤਿ ਸੰਬਾਦੰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sivā sakat saṃbādaṅ",
      "translation_ru": "даже если читает повествования о беседе Шивы и Парвати,"
    },
    {
      "index": 34,
      "verse_id": 37098,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਛੋਡਿ ਛੋਡਿ ਸਗਲ ਭੇਦੰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man chhoḍ chhoḍ sagal bhedaṅ",
      "translation_ru": "о мой ум, оставь, оставь все эти дела: они создают отделённость от Бога."
    },
    {
      "index": 35,
      "verse_id": 37099,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਗੋਬਿੰਦੰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "simar simar gobindaṅ",
      "translation_ru": "Снова и снова вспоминай Гобинда."
    },
    {
      "index": 36,
      "verse_id": 37100,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਭਜੁ ਨਾਮਾ ਤਰਸਿ ਭਵ ਸਿੰਧੰ ॥੪॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bhaj nāmā taras bhav sindhaṅ",
      "translation_ru": "О Намдев, воспевай Имя: только так переплывёшь океан мира."
    },
    {
      "index": 37,
      "verse_id": 37101,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੋਂਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "goṇḍ",
      "translation_ru": "Гонд."
    },
    {
      "index": 38,
      "verse_id": 37102,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਦ ਭ੍ਰਮੇ ਜੈਸੇ ਮਿਰਗਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nād bhrame jaise mirgāe",
      "translation_ru": "Как олень, забыв себя, бежит за звуком ловчего инструмента,"
    },
    {
      "index": 39,
      "verse_id": 37103,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਾਨ ਤਜੇ ਵਾ ਕੋ ਧਿਆਨੁ ਨ ਜਾਏ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prān taje vā ko dhiān na jāe",
      "translation_ru": "он отдаёт жизнь, но память об этом звуке не покидает его."
    },
    {
      "index": 40,
      "verse_id": 37104,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਐਸੇ ਰਾਮਾ ਐਸੇ ਹੇਰਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "aise rāmā aise herau",
      "translation_ru": "Так и я смотрю на своего возлюбленного Рама."
    },
    {
      "index": 41,
      "verse_id": 37105,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮੁ ਛੋਡਿ ਚਿਤੁ ਅਨਤ ਨ ਫੇਰਉ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rām chhoḍ chit anat na pherau",
      "translation_ru": "Оставив память о Раме, я не обращаю свой ум никуда в сторону. Пауза."
    },
    {
      "index": 42,
      "verse_id": 37106,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਉ ਮੀਨਾ ਹੇਰੈ ਪਸੂਆਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jiu mīnā herai pasūārā",
      "translation_ru": "Как рыбак пристально смотрит на рыб,"
    },
    {
      "index": 43,
      "verse_id": 37107,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਨਾ ਗਢਤੇ ਹਿਰੈ ਸੁਨਾਰਾ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sonā gaḍhte hirai sunārā",
      "translation_ru": "как ювелир, обрабатывая золото, внимательно смотрит на него,"
    },
    {
      "index": 44,
      "verse_id": 37108,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਉ ਬਿਖਈ ਹੇਰੈ ਪਰ ਨਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jiu bikhī herai par nārī",
      "translation_ru": "как чувственный человек смотрит на чужую женщину,"
    },
    {
      "index": 45,
      "verse_id": 37109,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਉਡਾ ਡਾਰਤ ਹਿਰੈ ਜੁਆਰੀ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kauḍā ḍārat hirai juārī",
      "translation_ru": "как игрок, бросив каури, пристально смотрит, какой выпал ход,"
    },
    {
      "index": 46,
      "verse_id": 37110,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਹ ਜਹ ਦੇਖਉ ਤਹ ਤਹ ਰਾਮਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jah jah dekhau tah tah rāmā",
      "translation_ru": "куда бы я ни смотрел, везде вижу Рама."
    },
    {
      "index": 47,
      "verse_id": 37111,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਕੇ ਚਰਨ ਨਿਤ ਧਿਆਵੈ ਨਾਮਾ ॥੪॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har ke charan nit dhiāvai nāmā",
      "translation_ru": "Намдев постоянно созерцает стопы Хари."
    },
    {
      "index": 48,
      "verse_id": 37112,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੋਂਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "goṇḍ",
      "translation_ru": "Гонд."
    },
    {
      "index": 49,
      "verse_id": 37113,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੋ ਕਉ ਤਾਰਿ ਲੇ ਰਾਮਾ ਤਾਰਿ ਲੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mo kau tār le rāmā tār le",
      "translation_ru": "О Рам, переправь меня, спаси меня через океан мира."
    },
    {
      "index": 50,
      "verse_id": 37114,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੈ ਅਜਾਨੁ ਜਨੁ ਤਰਿਬੇ ਨ ਜਾਨਉ ਬਾਪ ਬੀਠੁਲਾ ਬਾਹ ਦੇ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mai ajān jan taribe na jānau bāp bīṭhulā bāh de",
      "translation_ru": "О отец Битхул, дай мне свою руку: я твой неразумный слуга и не умею переплывать. Пауза."
    },
    {
      "index": 51,
      "verse_id": 37115,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਰ ਤੇ ਸੁਰ ਹੋਇ ਜਾਤ ਨਿਮਖ ਮੈ ਸਤਿਗੁਰ ਬੁਧਿ ਸਿਖਲਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nar te sur hoi jāt nimakh mai satgur budh sikhlāī",
      "translation_ru": "По наставлению Сатгуру человек в мгновение ока становится подобным божеству."
    },
    {
      "index": 52,
      "verse_id": 37116,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਰ ਤੇ ਉਪਜਿ ਸੁਰਗ ਕਉ ਜੀਤਿਓ ਸੋ ਅਵਖਧ ਮੈ ਪਾਈ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nar te upaj surag kau jītio so avakhadh mai pāī",
      "translation_ru": "Пусть я получу то лекарство, благодаря которому, родившись человеком, можно победить даже желание небес."
    },
    {
      "index": 53,
      "verse_id": 37117,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਹਾ ਜਹਾ ਧੂਅ ਨਾਰਦੁ ਟੇਕੇ ਨੈਕੁ ਟਿਕਾਵਹੁ ਮੋਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jahā jahā dhūa nārad ṭeke naik ṭikāvahu mohi",
      "translation_ru": "В какие духовные состояния Ты утвердил Дхру и Нарада, туда же навсегда утверди и меня."
    },
    {
      "index": 54,
      "verse_id": 37118,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤੇਰੇ ਨਾਮ ਅਵਿਲੰਬਿ ਬਹੁਤੁ ਜਨ ਉਧਰੇ ਨਾਮੇ ਕੀ ਨਿਜ ਮਤਿ ਏਹ ॥੨॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tere nām avilaṃb bahut jan udhre nāme kī nij mat eh",
      "translation_ru": "Твёрдое убеждение Намдева таково: опираясь на Твоё Имя, бесчисленные люди спаслись от пороков океана мира."
    }
  ]
}