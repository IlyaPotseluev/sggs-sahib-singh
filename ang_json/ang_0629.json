{
  "ang": 629,
  "line_count": 61,
  "lines": [
    {
      "index": 1,
      "verse_id": 27269,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਆਰਾਧੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūrā ārādhe ॥",
      "translation_ru": "Те люди, которые созерцали совершенного Гуру,"
    },
    {
      "index": 2,
      "verse_id": 27270,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਾਰਜ ਸਗਲੇ ਸਾਧੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kāraj saglē sādhē ॥",
      "translation_ru": "они устроили все свои дела."
    },
    {
      "index": 3,
      "verse_id": 27271,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪੂਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagal manorath pūrē ॥",
      "translation_ru": "Все их сердечные желания исполнились."
    },
    {
      "index": 4,
      "verse_id": 27272,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਾਜੇ ਅਨਹਦ ਤੂਰੇ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bājē anhad tūre ॥1॥",
      "translation_ru": "Внутри них непрерывно звучат трубы хвалы Господу."
    },
    {
      "index": 5,
      "verse_id": 27273,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਹੁ ਰਾਮੁ ਜਪਤ ਸੁਖੁ ਪਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santahu rām japat sukh pāiā ॥",
      "translation_ru": "О святые, повторяя Имя Бога, они наслаждаются духовным покоем."
    },
    {
      "index": 6,
      "verse_id": 27274,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਅਸਥਾਨਿ ਬਸੇ ਸੁਖ ਸਹਜੇ ਸਗਲੇ ਦੂਖ ਮਿਟਾਇਆ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant asthān basē sukh sahjē saglē dūkh miṭāiā ॥1॥ rahāu ॥",
      "translation_ru": "Те, кто обосновался в месте святых, в Садх Сангат, пребывая в духовной устойчивости, обрели духовную радость и устранили все страдания."
    },
    {
      "index": 7,
      "verse_id": 27275,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਬਾਣੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūrē kī bāṇī ॥",
      "translation_ru": "Бани совершенного Гуру"
    },
    {
      "index": 8,
      "verse_id": 27276,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਮਨਿ ਭਾਣੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pārbrahm man bhāṇī ॥",
      "translation_ru": "любима в уме Парабрахма."
    },
    {
      "index": 9,
      "verse_id": 27277,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਦਾਸਿ ਵਖਾਣੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak dās vakhāṇī ॥",
      "translation_ru": "О Нанак, лишь редкий слуга произнёс её, пребывая в духовной устойчивости."
    },
    {
      "index": 10,
      "verse_id": 27278,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਿਰਮਲ ਅਕਥ ਕਹਾਣੀ ॥੨॥੧੮॥੮੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nirmal akath kahāṇī ॥2॥18॥82॥",
      "translation_ru": "Это чистая, очищающая жизнь хвала Тому Господу, чей образ невозможно описать."
    },
    {
      "index": 11,
      "verse_id": 27279,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahalā 5 ॥",
      "translation_ru": "Соратх, Махала 5."
    },
    {
      "index": 12,
      "verse_id": 27280,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਭੂਖੇ ਖਾਵਤ ਲਾਜ ਨ ਆਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bhūkhē khāvat lāj na āvē ॥",
      "translation_ru": "Как голодный человек, получив еду, не чувствует стыда, когда ест,"
    },
    {
      "index": 13,
      "verse_id": 27281,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਉ ਹਰਿ ਜਨੁ ਹਰਿ ਗੁਣ ਗਾਵੈ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tiu har jan har guṇ gāvē ॥1॥",
      "translation_ru": "так слуга Господа с большим желанием поёт песни хвалы Господу, чтобы утолить свою духовную жажду."
    },
    {
      "index": 14,
      "verse_id": 27282,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪਨੇ ਕਾਜ ਕਉ ਕਿਉ ਅਲਕਾਈਐ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apnē kāj kau kiu alkāīē ॥",
      "translation_ru": "Почему же лениться ради своего истинного дела?"
    },
    {
      "index": 15,
      "verse_id": 27283,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਤੁ ਸਿਮਰਨਿ ਦਰਗਹ ਮੁਖੁ ਊਜਲ ਸਦਾ ਸਦਾ ਸੁਖੁ ਪਾਈਐ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jit simran dargah mukh ūjal sadā sadā sukh pāīē ॥1॥ rahāu ॥",
      "translation_ru": "Благодаря этому симрану человек становится светлоликим в присутствии Бога и всегда наслаждается духовным блаженством."
    },
    {
      "index": 16,
      "verse_id": 27284,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਉ ਕਾਮੀ ਕਾਮਿ ਲੁਭਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jiu kāmī kām lubhāvē ॥",
      "translation_ru": "Как чувственный человек остаётся поглощённым страстью,"
    },
    {
      "index": 17,
      "verse_id": 27285,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਉ ਹਰਿ ਦਾਸ ਹਰਿ ਜਸੁ ਭਾਵੈ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tiu har dās har jas bhāvē ॥2॥",
      "translation_ru": "так слуге Господа нравится только хвала Господу."
    },
    {
      "index": 18,
      "verse_id": 27286,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਉ ਮਾਤਾ ਬਾਲਿ ਲਪਟਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jiu mātā bāl laṭpāvē ॥",
      "translation_ru": "Как мать привязана любовью к своему ребёнку,"
    },
    {
      "index": 19,
      "verse_id": 27287,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਉ ਗਿਆਨੀ ਨਾਮੁ ਕਮਾਵੈ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tiu giānī nām kamāvē ॥3॥",
      "translation_ru": "так человек духовного понимания совершает труд практики Имени."
    },
    {
      "index": 20,
      "verse_id": 27288,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਪਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūrē tē pāvē ॥",
      "translation_ru": "Но получает этот дар только тот, кто получает его от совершенного Гуру."
    },
    {
      "index": 21,
      "verse_id": 27289,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਨ ਨਾਨਕ ਨਾਮੁ ਧਿਆਵੈ ॥੪॥੧੯॥੮੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jan nānak nām dhiāvē ॥4॥19॥83॥",
      "translation_ru": "О слуга Нанак, такой человек созерцает Имя Бога."
    },
    {
      "index": 22,
      "verse_id": 27290,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahalā 5 ॥",
      "translation_ru": "Соратх, Махала 5."
    },
    {
      "index": 23,
      "verse_id": 27291,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੁਖ ਸਾਂਦਿ ਘਰਿ ਆਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sukh sānd ghar āiā ॥",
      "translation_ru": "Он в полном духовном здоровье вернулся и утвердился в доме своего сердца."
    },
    {
      "index": 24,
      "verse_id": 27292,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਿੰਦਕ ਕੈ ਮੁਖਿ ਛਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nindak kai mukh chhāiā ॥",
      "translation_ru": "На лицо клеветника легла зола: клеветник слуги Господа обрёл лишь пятно бесчестья."
    },
    {
      "index": 25,
      "verse_id": 27293,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੂਰੈ ਗੁਰਿ ਪਹਿਰਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pūrai gur pahirāiā ॥",
      "translation_ru": "Совершенный Гуру даровал ему почёт и уважение."
    },
    {
      "index": 26,
      "verse_id": 27294,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨਸੇ ਦੁਖ ਸਬਾਇਆ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "binsē dukh sabāiā ॥1॥",
      "translation_ru": "Все его страдания исчезли."
    },
    {
      "index": 27,
      "verse_id": 27295,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਹੁ ਸਾਚੇ ਕੀ ਵਡਿਆਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santahu sāchē kī vaḍiāī ॥",
      "translation_ru": "О святые, велика слава и сила Вечного Бога."
    },
    {
      "index": 28,
      "verse_id": 27296,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਨਿ ਅਚਰਜ ਸੋਭ ਬਣਾਈ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jin acharaj sobh baṇāī ॥1॥ rahāu ॥",
      "translation_ru": "Он создал удивительную славу для своего слуги."
    },
    {
      "index": 29,
      "verse_id": 27297,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੋਲੇ ਸਾਹਿਬ ਕੈ ਭਾਣੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bolē sāhib kai bhāṇai ॥",
      "translation_ru": "Слуга, которому Гуру даровал честь, всегда говорит в воле Господа."
    },
    {
      "index": 30,
      "verse_id": 27298,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦਾਸੁ ਬਾਣੀ ਬ੍ਰਹਮੁ ਵਖਾਣੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dās bāṇī brahm vakhāṇai ॥",
      "translation_ru": "Этот слуга всегда произносит Бани хвалы Богу и произносит Имя Бога."
    },
    {
      "index": 31,
      "verse_id": 27299,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸੁਖਦਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak prabh sukhdāī ॥",
      "translation_ru": "О Нанак, Господь всегда даёт покой своему слуге."
    },
    {
      "index": 32,
      "verse_id": 27300,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਨਿ ਪੂਰੀ ਬਣਤ ਬਣਾਈ ॥੨॥੨੦॥੮੪॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jin pūrī baṇat baṇāī ॥2॥20॥84॥",
      "translation_ru": "Именно Он устроил безошибочный порядок: через прибежище Гуру обретается симран Имени."
    },
    {
      "index": 33,
      "verse_id": 27301,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahalā 5 ॥",
      "translation_ru": "Соратх, Махала 5."
    },
    {
      "index": 34,
      "verse_id": 27302,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭੁ ਅਪੁਨਾ ਰਿਦੈ ਧਿਆਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh apunā ridai dhiāē ॥",
      "translation_ru": "Тот человек, кто держит Имя Бога в своём сердце,"
    },
    {
      "index": 35,
      "verse_id": 27303,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਘਰਿ ਸਹੀ ਸਲਾਮਤਿ ਆਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ghar sahī salāmat āē ॥",
      "translation_ru": "сохраняет капитал духовной жизни от пороков и пребывает в доме сердца, у стоп Господа."
    },
    {
      "index": 36,
      "verse_id": 27304,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤੋਖੁ ਭਇਆ ਸੰਸਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santokh bhaiā sansārē ॥",
      "translation_ru": "Даже живя в мире и занимаясь мирскими делами, он сохраняет в уме удовлетворённость."
    },
    {
      "index": 37,
      "verse_id": 27305,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਲੈ ਤਾਰੇ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūrai lai tārē ॥1॥",
      "translation_ru": "Совершенный Гуру, взяв его за руку, переправляет его через океан мира."
    },
    {
      "index": 38,
      "verse_id": 27306,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਹੁ ਪ੍ਰਭੁ ਮੇਰਾ ਸਦਾ ਦਇਆਲਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santahu prabh merā sadā daiālā ॥",
      "translation_ru": "О святые, мой Господь всегда милостив к своим слугам."
    },
    {
      "index": 39,
      "verse_id": 27307,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪਨੇ ਭਗਤ ਕੀ ਗਣਤ ਨ ਗਣਈ ਰਾਖੈ ਬਾਲ ਗੁਪਾਲਾ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apnē bhagat kī gaṇat na gaṇaī rākhai bāl gupālā ॥1॥ rahāu ॥",
      "translation_ru": "Господь не рассматривает счёт поступков своих преданных, потому что, как детей, Он сохраняет их от пороков."
    },
    {
      "index": 40,
      "verse_id": 27308,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਨਾਮੁ ਰਿਦੈ ਉਰਿ ਧਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har nām ridai ur dhārē ॥",
      "translation_ru": "Тот, кто удерживает Имя Господа в своём сердце,"
    },
    {
      "index": 41,
      "verse_id": 27309,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਨਿ ਸਭੇ ਥੋਕ ਸਵਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tin sabhē thok savārē ॥",
      "translation_ru": "тот украсил и привёл в порядок все свои духовные качества."
    },
    {
      "index": 42,
      "verse_id": 27310,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਤੁਸਿ ਦੀਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūrai tus dīā ॥",
      "translation_ru": "Совершенный Гуру, будучи доволен, даровал ему дар Имени."
    },
    {
      "index": 43,
      "verse_id": 27311,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਫਿਰਿ ਨਾਨਕ ਦੂਖੁ ਨ ਥੀਆ ॥੨॥੨੧॥੮੫॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "phir nānak dūkh na thīā ॥2॥21॥85॥",
      "translation_ru": "О Нанак, после этого никакое страдание уже не смогло коснуться его."
    },
    {
      "index": 44,
      "verse_id": 27312,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahalā 5 ॥",
      "translation_ru": "Соратх, Махала 5."
    },
    {
      "index": 45,
      "verse_id": 27313,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਮਨਿ ਤਨਿ ਵਸਿਆ ਸੋਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har man tan vasiā soī ॥",
      "translation_ru": "У того человека, в чьём уме и теле пребывает один Господь,"
    },
    {
      "index": 46,
      "verse_id": 27314,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਕਰੇ ਸਭੁ ਕੋਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jai jai kār karē sabh koī ॥",
      "translation_ru": "каждое живое существо прославляет его."
    },
    {
      "index": 47,
      "verse_id": 27315,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਵਡਿਆਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūrē kī vaḍiāī ॥",
      "translation_ru": "Это благословение совершенного Гуру."
    },
    {
      "index": 48,
      "verse_id": 27316,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਾ ਕੀ ਕੀਮਤਿ ਕਹੀ ਨ ਜਾਈ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tā kī kīmat kahī na jāī ॥1॥",
      "translation_ru": "Цену этому благословению невозможно назвать."
    },
    {
      "index": 49,
      "verse_id": 27317,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਉ ਕੁਰਬਾਨੁ ਜਾਈ ਤੇਰੇ ਨਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "hau kurbān jāī terē nāvai ॥",
      "translation_ru": "О мой любимый Господь, я жертвую собой ради Твоего Имени."
    },
    {
      "index": 50,
      "verse_id": 27318,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਸ ਨੋ ਬਖਸਿ ਲੈਹਿ ਮੇਰੇ ਪਿਆਰੇ ਸੋ ਜਸੁ ਤੇਰਾ ਗਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jis no bakhas laih merē piārē so jas terā gāvē ॥1॥ rahāu ॥",
      "translation_ru": "Тот, на кого Ты изливаешь милость, о мой любимый, всегда поёт песнь Твоей хвалы."
    },
    {
      "index": 51,
      "verse_id": 27319,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤੂੰ ਭਾਰੋ ਸੁਆਮੀ ਮੇਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tūṅ bhāro suāmī merā ॥",
      "translation_ru": "О Господь, Ты мой великий Владыка."
    },
    {
      "index": 52,
      "verse_id": 27320,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤਾਂ ਭਰਵਾਸਾ ਤੇਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "santāṅ bharvāsā terā ॥",
      "translation_ru": "Твоим святым также остаётся только Твоя опора."
    },
    {
      "index": 53,
      "verse_id": 27321,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak prabh sarṇāī ॥",
      "translation_ru": "О Нанак, тот, кто остаётся в прибежище Господа,"
    },
    {
      "index": 54,
      "verse_id": 27322,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੁਖਿ ਨਿੰਦਕ ਕੈ ਛਾਈ ॥੨॥੨੨॥੮੬॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mukh nindak kai chhāī ॥2॥22॥86॥",
      "translation_ru": "на лицо его клеветника падает зола: никто не может повредить человеку, нашедшему прибежище у Господа."
    },
    {
      "index": 55,
      "verse_id": 27323,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh mahalā 5 ॥",
      "translation_ru": "Соратх, Махала 5."
    },
    {
      "index": 56,
      "verse_id": 27324,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਗੈ ਸੁਖੁ ਮੇਰੇ ਮੀਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "āgai sukh merē mītā ॥",
      "translation_ru": "Впереди — покой, о мой друг."
    },
    {
      "index": 57,
      "verse_id": 27325,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਛੇ ਆਨਦੁ ਪ੍ਰਭਿ ਕੀਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāchhē ānad prabh kītā ॥",
      "translation_ru": "Позади Господь тоже сотворил радость."
    },
    {
      "index": 58,
      "verse_id": 27326,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਰਮੇਸੁਰਿ ਬਣਤ ਬਣਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "parmesur baṇat baṇāī ॥",
      "translation_ru": "Верховный Господь устроил весь порядок."
    },
    {
      "index": 59,
      "verse_id": 27327,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਫਿਰਿ ਡੋਲਤ ਕਤਹੂ ਨਾਹੀ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "phir ḍolat katahū nāhī ॥1॥",
      "translation_ru": "Поэтому теперь нигде больше нет колебания."
    },
    {
      "index": 60,
      "verse_id": 27328,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਚੇ ਸਾਹਿਬ ਸਿਉ ਮਨੁ ਮਾਨਿਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sāchē sāhib siu man māniā ॥",
      "translation_ru": "Ум согласился и соединился с Истинным Господом."
    },
    {
      "index": 61,
      "verse_id": 27329,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਸਰਬ ਨਿਰੰਤਰਿ ਜਾਨਿਆ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har sarab nirantar jāniā ॥1॥ rahāu ॥",
      "translation_ru": "Господь познан как пребывающий во всём без промежутка."
    }
  ]
}