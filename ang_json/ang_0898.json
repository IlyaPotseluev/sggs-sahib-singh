{
  "ang": 898,
  "line_count": 58,
  "lines": [
    {
      "index": 1,
      "verse_id": 38305,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rāmkali mahallā 5",
      "translation_ru": "Рамкали, Махала 5."
    },
    {
      "index": 2,
      "verse_id": 38306,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਿਸੁ ਭਰਵਾਸੈ ਬਿਚਰਹਿ ਭਵਨ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kis bharvāsē bichrah bhavan",
      "translation_ru": "О глупец, на чью опору, кроме Бога, ты рассчитываешь, странствуя в мире?"
    },
    {
      "index": 3,
      "verse_id": 38307,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੂੜ ਮੁਗਧ ਤੇਰਾ ਸੰਗੀ ਕਵਨ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mūṛ mugadh terā saṅgī kavan",
      "translation_ru": "О глупец, кто, кроме Бога, может быть твоим настоящим спутником?"
    },
    {
      "index": 4,
      "verse_id": 38308,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮੁ ਸੰਗੀ ਤਿਸੁ ਗਤਿ ਨਹੀ ਜਾਨਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rām saṅgī tis gat nahī jānah",
      "translation_ru": "Твой истинный спутник — Господь, но ты не устанавливаешь с Ним близости."
    },
    {
      "index": 5,
      "verse_id": 38309,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੰਚ ਬਟਵਾਰੇ ਸੇ ਮੀਤ ਕਰਿ ਮਾਨਹਿ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pañch baṭvāre se mīt kar mānah",
      "translation_ru": "Пять разбойников — страсти и пороки — ты считаешь своими друзьями."
    },
    {
      "index": 6,
      "verse_id": 38310,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋ ਘਰੁ ਸੇਵਿ ਜਿਤੁ ਉਧਰਹਿ ਮੀਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "so ghar sev jit udhrah mīt",
      "translation_ru": "О друг, держись того пристанища, через которое ты сможешь переправиться через мир-океан."
    },
    {
      "index": 7,
      "verse_id": 38311,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਣ ਗੋਵਿੰਦ ਰਵੀਅਹਿ ਦਿਨੁ ਰਾਤੀ ਸਾਧਸੰਗਿ ਕਰਿ ਮਨ ਕੀ ਪ੍ਰੀਤਿ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "guṇ govind ravīah din rātī sādhasaṅg kar man kī prīt",
      "translation_ru": "В общении с Гуру соедини любовь своего ума с этим местом; там днём и ночью следует воспевать достоинства Говинда."
    },
    {
      "index": 8,
      "verse_id": 38312,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਨਮੁ ਬਿਹਾਨੋ ਅਹੰਕਾਰਿ ਅਰੁ ਵਾਦਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "janam bihāno ahaṅkār ar vād",
      "translation_ru": "Жизнь человека проходит в гордыне и спорах."
    },
    {
      "index": 9,
      "verse_id": 38313,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤ੍ਰਿਪਤਿ ਨ ਆਵੈ ਬਿਖਿਆ ਸਾਦਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tripat na āvē bikhiyā sād",
      "translation_ru": "Во вкусе майи он никогда не находит удовлетворения и не насыщается."
    },
    {
      "index": 10,
      "verse_id": 38314,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਭਰਮਤ ਭਰਮਤ ਮਹਾ ਦੁਖੁ ਪਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bharamat bharamat mahā dukh pāiā",
      "translation_ru": "Блуждая снова и снова, он испытывает великие страдания."
    },
    {
      "index": 11,
      "verse_id": 38315,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਰੀ ਨ ਜਾਈ ਦੁਤਰ ਮਾਇਆ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tarī na jāī dutar māiā",
      "translation_ru": "Майя — труднопреодолимый океан; без Имени Господа через него не переправиться."
    },
    {
      "index": 12,
      "verse_id": 38316,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਾਮਿ ਨ ਆਵੈ ਸੁ ਕਾਰ ਕਮਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kām na āvē so kār kamāvē",
      "translation_ru": "Человек всё время делает такие дела, которые в конце не приносят ему пользы."
    },
    {
      "index": 13,
      "verse_id": 38317,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਪਿ ਬੀਜਿ ਆਪੇ ਹੀ ਖਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "āp bīj āpe hī khāvē",
      "translation_ru": "Сам посеяв семена дурных дел, он сам же вкушает их горький плод."
    },
    {
      "index": 14,
      "verse_id": 38318,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਖਨ ਕਉ ਦੂਸਰ ਨਹੀ ਕੋਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rākhan kau dūsar nahī koi",
      "translation_ru": "Кроме Бога, нет никого другого, кто мог бы спасти его от этой беды."
    },
    {
      "index": 15,
      "verse_id": 38319,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਉ ਨਿਸਤਰੈ ਜਉ ਕਿਰਪਾ ਹੋਇ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tau nistarē jau kirpā hoi",
      "translation_ru": "Лишь когда приходит милость Бога, человек переправляется через это."
    },
    {
      "index": 16,
      "verse_id": 38320,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਤਿਤ ਪੁਨੀਤ ਪ੍ਰਭ ਤੇਰੋ ਨਾਮੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "patit punīt prabh tero nām",
      "translation_ru": "О Господь, Твоё Имя очищает тех, кто пал в пороки."
    },
    {
      "index": 17,
      "verse_id": 38321,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪਨੇ ਦਾਸ ਕਉ ਕੀਜੈ ਦਾਨੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apne dās kau kījē dān",
      "translation_ru": "Дай мне, Твоему слуге, дар Твоего Имени."
    },
    {
      "index": 18,
      "verse_id": 38322,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਗਤਿ ਕਰਿ ਮੇਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kar kirpā prabh gat kar merī",
      "translation_ru": "О Господь, яви милость и возвышай моё духовное состояние."
    },
    {
      "index": 19,
      "verse_id": 38323,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਰਣਿ ਗਹੀ ਨਾਨਕ ਪ੍ਰਭ ਤੇਰੀ ॥੪॥੩੭॥੪੮॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "saraṇ gahī nānak prabh terī",
      "translation_ru": "О Господь, Нанак ухватился за Твоё прибежище."
    },
    {
      "index": 20,
      "verse_id": 38324,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rāmkali mahallā 5",
      "translation_ru": "Рамкали, Махала 5."
    },
    {
      "index": 21,
      "verse_id": 38325,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਇਹ ਲੋਕੇ ਸੁਖੁ ਪਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ih loke sukh pāiā",
      "translation_ru": "Тот, кто обрёл дружбу Гуру, наслаждается духовным покоем в этом мире."
    },
    {
      "index": 22,
      "verse_id": 38326,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਹੀ ਭੇਟਤ ਧਰਮ ਰਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nahī bheṭat dharam rāiā",
      "translation_ru": "В ином мире ему не приходится иметь дело с Дхарам Раджем."
    },
    {
      "index": 23,
      "verse_id": 38327,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਦਰਗਹ ਸੋਭਾਵੰਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har dargah sobhāvant",
      "translation_ru": "В присутствии Бога он становится почитаемым."
    },
    {
      "index": 24,
      "verse_id": 38328,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਫੁਨਿ ਗਰਭਿ ਨਾਹੀ ਬਸੰਤ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "phun garabh nāhī basant",
      "translation_ru": "И снова он не попадает в круг рождений."
    },
    {
      "index": 25,
      "verse_id": 38329,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਾਨੀ ਸੰਤ ਕੀ ਮਿਤ੍ਰਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jānī sant kī mitrāī",
      "translation_ru": "Теперь я понял ценность дружбы Гуру."
    },
    {
      "index": 26,
      "verse_id": 38330,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਦੀਨੋ ਹਰਿ ਨਾਮਾ ਪੂਰਬਿ ਸੰਜੋਗਿ ਮਿਲਾਈ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kar kirpā dīno har nāmā pūrab sanjog milāī",
      "translation_ru": "По прежнему благому союзу эта дружба была обретена; Гуру, явив милость, дал мне Имя Бога."
    },
    {
      "index": 27,
      "verse_id": 38331,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਕੈ ਚਰਣਿ ਚਿਤੁ ਲਾਗਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur kē charaṇ chit lāgā",
      "translation_ru": "Моё сознание соединилось со стопами Гуру."
    },
    {
      "index": 28,
      "verse_id": 38332,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧੰਨਿ ਧੰਨਿ ਸੰਜੋਗੁ ਸਭਾਗਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhann dhann sanjog sabhāgā",
      "translation_ru": "Благословен, благословен и счастлив был тот миг встречи."
    },
    {
      "index": 29,
      "verse_id": 38333,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਕੀ ਧੂਰਿ ਲਾਗੀ ਮੇਰੈ ਮਾਥੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant kī dhūṛ lāgī merē māthe",
      "translation_ru": "Пыль стоп Гуру коснулась моего лба."
    },
    {
      "index": 30,
      "verse_id": 38334,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਿਲਵਿਖ ਦੁਖ ਸਗਲੇ ਮੇਰੇ ਲਾਥੇ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kilvikh dukh sagle mere lāthe",
      "translation_ru": "Все мои грехи и страдания были удалены."
    },
    {
      "index": 31,
      "verse_id": 38335,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧ ਕੀ ਸਚੁ ਟਹਲ ਕਮਾਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādh kī sach ṭahal kamānī",
      "translation_ru": "Когда живые существа с верой совершают служение Гуру,"
    },
    {
      "index": 32,
      "verse_id": 38336,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਬ ਹੋਏ ਮਨ ਸੁਧ ਪਰਾਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tab hoe man sudh parānī",
      "translation_ru": "тогда, о человек, их умы становятся чистыми."
    },
    {
      "index": 33,
      "verse_id": 38337,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਨ ਕਾ ਸਫਲ ਦਰਸੁ ਡੀਠਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jan kā saphal daras ḍīṭhā",
      "translation_ru": "Тот, кто увидел плодотворный даршан слуги Бога, обрёл плод Имени."
    },
    {
      "index": 34,
      "verse_id": 38338,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮੁ ਪ੍ਰਭੂ ਕਾ ਘਟਿ ਘਟਿ ਵੂਠਾ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām prabhū kā ghaṭ ghaṭ vūṭhā",
      "translation_ru": "Имя Господа, вообще-то, пребывает в каждом сердце."
    },
    {
      "index": 35,
      "verse_id": 38339,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਿਟਾਨੇ ਸਭਿ ਕਲਿ ਕਲੇਸ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "miṭāne sabh kal kales",
      "translation_ru": "Благодаря встрече с Гуру все внутренние споры и страдания исчезают."
    },
    {
      "index": 36,
      "verse_id": 38340,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਸ ਤੇ ਉਪਜੇ ਤਿਸੁ ਮਹਿ ਪਰਵੇਸ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jis te upje tis mah parves",
      "translation_ru": "Живые существа растворяются в Том, от Кого они возникли."
    },
    {
      "index": 37,
      "verse_id": 38341,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਗਟੇ ਆਨੂਪ ਗੋੁਵਿੰਦ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pragaṭe ānūp govind",
      "translation_ru": "Прекрасный, несравненный Говинд проявляется в сердце."
    },
    {
      "index": 38,
      "verse_id": 38342,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭ ਪੂਰੇ ਨਾਨਕ ਬਖਸਿੰਦ ॥੪॥੩੮॥੪੯॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh pūre nānak bakhasind",
      "translation_ru": "О Нанак, проявляется совершенный Господь, дарующий прощение."
    },
    {
      "index": 39,
      "verse_id": 38343,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rāmkali mahallā 5",
      "translation_ru": "Рамкали, Махала 5."
    },
    {
      "index": 40,
      "verse_id": 38344,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਊ ਕਉ ਚਾਰੇ ਸਾਰਦੂਲੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gaū kau chāre sāradūl",
      "translation_ru": "Когда Господь смотрит милостивым взором, ставший сильным ум держит органы познания под контролем."
    },
    {
      "index": 41,
      "verse_id": 38345,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਉਡੀ ਕਾ ਲਖ ਹੂਆ ਮੂਲੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kauḍī kā lakh hūā mūl",
      "translation_ru": "Живое существо, прежде ставшее ничтожным, словно каури, теперь обретает цену в сотни тысяч."
    },
    {
      "index": 42,
      "verse_id": 38346,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਕਰੀ ਕਉ ਹਸਤੀ ਪ੍ਰਤਿਪਾਲੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bakrī kau hastī pratipāle",
      "translation_ru": "Тогда прежде гордый, как слон, ум принимает в себе смиренный нрав, подобный козе."
    },
    {
      "index": 43,
      "verse_id": 38347,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪਨਾ ਪ੍ਰਭੁ ਨਦਰਿ ਨਿਹਾਲੇ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apnā prabh nadar nihāle",
      "translation_ru": "Так происходит, когда свой возлюбленный Господь смотрит милостивым взором."
    },
    {
      "index": 44,
      "verse_id": 38348,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕ੍ਰਿਪਾ ਨਿਧਾਨ ਪ੍ਰੀਤਮ ਪ੍ਰਭ ਮੇਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kripā nidhān prītam prabh mere",
      "translation_ru": "О мой возлюбленный Господь, о сокровищница милости!"
    },
    {
      "index": 45,
      "verse_id": 38349,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਰਨਿ ਨ ਸਾਕਉ ਬਹੁ ਗੁਨ ਤੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "baran na sākau bah guṇ tere",
      "translation_ru": "Твои качества бесчисленны; я не могу описать их все."
    },
    {
      "index": 46,
      "verse_id": 38350,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦੀਸਤ ਮਾਸੁ ਨ ਖਾਇ ਬਿਲਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dīsat mās na khāe bilāī",
      "translation_ru": "Когда Господь смотрит милостиво, кошка не ест мясо, которое видит; жажда ума прекращается."
    },
    {
      "index": 47,
      "verse_id": 38351,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਹਾ ਕਸਾਬਿ ਛੁਰੀ ਸਟਿ ਪਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mahā kasāb chhurī saṭ pāī",
      "translation_ru": "По милости Господа великий мясник, безжалостный ум, бросает нож из рук."
    },
    {
      "index": 48,
      "verse_id": 38352,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਣਹਾਰ ਪ੍ਰਭੁ ਹਿਰਦੈ ਵੂਠਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "karaṇhār prabh hirdē vūṭhā",
      "translation_ru": "Когда всемогущий Господь поселяется в сердце,"
    },
    {
      "index": 49,
      "verse_id": 38353,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਫਾਥੀ ਮਛੁਲੀ ਕਾ ਜਾਲਾ ਤੂਟਾ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "phāthī machhulī kā jālā ṭūṭā",
      "translation_ru": "тогда сеть майи разрывается для рыбы-души, попавшей в ловушку привязанности."
    },
    {
      "index": 50,
      "verse_id": 38354,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੂਕੇ ਕਾਸਟ ਹਰੇ ਚਲੂਲ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sūke kāsaṭ hare chalūl",
      "translation_ru": "Когда пришла милость, сухие деревья стали свежо-зелёными; сухость ума ушла, и внутри возникло сострадание."
    },
    {
      "index": 51,
      "verse_id": 38355,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਊਚੈ ਥਲਿ ਫੂਲੇ ਕਮਲ ਅਨੂਪ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ūchē thal phūle kamal anūp",
      "translation_ru": "На высоком сухом месте расцвели прекрасные лотосы; гордый ум, прежде не принимавший дождь Имени, теперь расцвёл."
    },
    {
      "index": 52,
      "verse_id": 38356,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਗਨਿ ਨਿਵਾਰੀ ਸਤਿਗੁਰ ਦੇਵ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "agan nivārī satigur dev",
      "translation_ru": "Возлюбленный Сатгуру устранил огонь жажды."
    },
    {
      "index": 53,
      "verse_id": 38357,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੇਵਕੁ ਅਪਨੀ ਲਾਇਓ ਸੇਵ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sevak apnī lāio sev",
      "translation_ru": "Он присоединил своего слугу к служению Себе."
    },
    {
      "index": 54,
      "verse_id": 38358,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਕਿਰਤਘਣਾ ਕਾ ਕਰੇ ਉਧਾਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "akiratghaṇā kā kare udhār",
      "translation_ru": "Господь переправляет даже неблагодарных."
    },
    {
      "index": 55,
      "verse_id": 38359,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਭੁ ਮੇਰਾ ਹੈ ਸਦਾ ਦਇਆਰੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabh merā hē sadā dēār",
      "translation_ru": "Мой Господь всегда является обителью милости."
    },
    {
      "index": 56,
      "verse_id": 38360,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਜਨਾ ਕਾ ਸਦਾ ਸਹਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant janā kā sadā sahāī",
      "translation_ru": "Господь всегда помогает святым людям."
    },
    {
      "index": 57,
      "verse_id": 38361,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਚਰਨ ਕਮਲ ਨਾਨਕ ਸਰਣਾਈ ॥੪॥੩੯॥੫੦॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "charaṇ kamal nānak saraṇāī",
      "translation_ru": "О Нанак, святые всегда пребывают в прибежище Его прекрасных лотосных стоп."
    },
    {
      "index": 58,
      "verse_id": 38362,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rāmkali mahallā 5",
      "translation_ru": "Рамкали, Махала 5."
    }
  ]
}
