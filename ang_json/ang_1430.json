{
  "ang": 1430,
  "line_count": 57,
  "lines": [
    {
      "index": 1,
      "verse_id": 60347,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੰਚ ਰਾਗਨੀ ਸੰਗਿ ਉਚਰਹੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pañch rāgnī saṅg uchrahī",
      "translation_ru": "Вместе произносятся пять рагини."
    },
    {
      "index": 2,
      "verse_id": 60348,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਥਮ ਭੈਰਵੀ ਬਿਲਾਵਲੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pratham bhērvī bilāvalī",
      "translation_ru": "Первыми идут Бхайрави и Билавали."
    },
    {
      "index": 3,
      "verse_id": 60349,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੁੰਨਿਆਕੀ ਗਾਵਹਿ ਬੰਗਲੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "punniākī gāvah baṅgalī",
      "translation_ru": "Затем поются Пунния и Бангали."
    },
    {
      "index": 4,
      "verse_id": 60350,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੁਨਿ ਅਸਲੇਖੀ ਕੀ ਭਈ ਬਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pun aslekhī kī bhaī bārī",
      "translation_ru": "Потом настала очередь Аслехи."
    },
    {
      "index": 5,
      "verse_id": 60351,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਏ ਭੈਰਉ ਕੀ ਪਾਚਉ ਨਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "e bhērau kī pāchau nārī",
      "translation_ru": "Это пять рагини рага Бхайрау: Бхайрави, Билавали, Пунния, Бангали и Аслехи."
    },
    {
      "index": 6,
      "verse_id": 60352,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੰਚਮ ਹਰਖ ਦਿਸਾਖ ਸੁਨਾਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pañcham harakh disākh sunāvah",
      "translation_ru": "Панчам, Харакх и Дисакх звучат."
    },
    {
      "index": 7,
      "verse_id": 60353,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੰਗਾਲਮ ਮਧੁ ਮਾਧਵ ਗਾਵਹਿ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "baṅgālam madh mādhav gāvahi",
      "translation_ru": "Бангалам, Мадх и Мадхав поются."
    },
    {
      "index": 8,
      "verse_id": 60354,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਲਲਤ ਬਿਲਾਵਲ ਗਾਵਹੀ ਅਪੁਨੀ ਅਪੁਨੀ ਭਾਂਤਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "lalat bilāval gāvahī apunī apunī bhāṅt",
      "translation_ru": "Лалат и Билавал поются каждый своим особым способом."
    },
    {
      "index": 9,
      "verse_id": 60355,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਸਟ ਪੁਤ੍ਰ ਭੈਰਵ ਕੇ ਗਾਵਹਿ ਗਾਇਨ ਪਾਤ੍ਰ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "asaṭ putra bhērav ke gāvahi gāyan pātra",
      "translation_ru": "Эти восемь сыновей рага Бхайрав — певцы, достойные пения: Панчам, Харакх, Дисакх, Бангалам, Мадх, Мадхав, Лалат и Билавал."
    },
    {
      "index": 10,
      "verse_id": 60356,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦੁਤੀਆ ਮਾਲਕਉਸਕ ਆਲਾਪਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dutīā mālakausak ālāpah",
      "translation_ru": "Вторым исполняется раг Малкаусак."
    },
    {
      "index": 11,
      "verse_id": 60357,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਗਿ ਰਾਗਨੀ ਪਾਚਉ ਥਾਪਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "saṅg rāgnī pāchau thāpah",
      "translation_ru": "Вместе с ним устанавливаются пять рагини."
    },
    {
      "index": 12,
      "verse_id": 60358,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੋਂਡਕਰੀ ਅਰੁ ਦੇਵਗੰਧਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "goṅḍkarī ar devgaṅdhārī",
      "translation_ru": "Это Гондкари и Девгандхари."
    },
    {
      "index": 13,
      "verse_id": 60359,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੰਧਾਰੀ ਸੀਹੁਤੀ ਉਚਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gaṅdhārī sīhutī uchārī",
      "translation_ru": "Также называются Гандхари и Сихути."
    },
    {
      "index": 14,
      "verse_id": 60360,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧਨਾਸਰੀ ਏ ਪਾਚਉ ਗਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhanāsrī e pāchau gāī",
      "translation_ru": "Дханасари тоже поётся среди этих пяти."
    },
    {
      "index": 15,
      "verse_id": 60361,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਾਲ ਰਾਗ ਕਉਸਕ ਸੰਗਿ ਲਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "māl rāg kausak saṅg lāī",
      "translation_ru": "Эти пять рагини соединены с рагом Малкаусак: Гондкари, Девгандхари, Гандхари, Сихути и Дханасари."
    },
    {
      "index": 16,
      "verse_id": 60362,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਾਰੂ ਮਸਤਅੰਗ ਮੇਵਾਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mārū masataṅg mevārā",
      "translation_ru": "Мару, Маст Анг и Мевара."
    },
    {
      "index": 17,
      "verse_id": 60363,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪ੍ਰਬਲਚੰਡ ਕਉਸਕ ਉਭਾਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "prabalchaṇḍ kausak ubhārā",
      "translation_ru": "Прабал Чанд, Каусак и Убхара."
    },
    {
      "index": 18,
      "verse_id": 60364,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਖਉਖਟ ਅਉ ਭਉਰਾਨਦ ਗਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "khaukhaṭ au bhaurānad gāe",
      "translation_ru": "Кхаукхат и Бхаурананд поются."
    },
    {
      "index": 19,
      "verse_id": 60365,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਸਟ ਮਾਲਕਉਸਕ ਸੰਗਿ ਲਾਏ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "asaṭ mālakausak saṅg lāe",
      "translation_ru": "Эти восемь сыновей соединены с Малкаусаком: Мару, Маст Анг, Мевара, Прабал Чанд, Каусак, Убхара, Кхаукхат и Бхаурананд."
    },
    {
      "index": 20,
      "verse_id": 60366,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੁਨਿ ਆਇਅਉ ਹਿੰਡੋਲੁ ਪੰਚ ਨਾਰਿ ਸੰਗਿ ਅਸਟ ਸੁਤ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pun āiau hiṅḍol pañch nār saṅg asaṭ sut",
      "translation_ru": "Затем приходит Хиндол вместе с пятью рагини и восемью сыновьями."
    },
    {
      "index": 21,
      "verse_id": 60367,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਉਠਹਿ ਤਾਨ ਕਲੋਲ ਗਾਇਨ ਤਾਰ ਮਿਲਾਵਹੀ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "uṭhahi tān kalol gāyan tār milāvahī",
      "translation_ru": "Поднимаются мелодии, звучит радостное пение, и певцы соединяют высокие струны."
    },
    {
      "index": 22,
      "verse_id": 60368,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤੇਲੰਗੀ ਦੇਵਕਰੀ ਆਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "telaṅgī devkarī āī",
      "translation_ru": "Пришли Теланги и Девкари."
    },
    {
      "index": 23,
      "verse_id": 60369,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਸੰਤੀ ਸੰਦੂਰ ਸੁਹਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "basantī sandūr suhāī",
      "translation_ru": "Также прекрасные Басенти и Сандур."
    },
    {
      "index": 24,
      "verse_id": 60370,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਰਸ ਅਹੀਰੀ ਲੈ ਭਾਰਜਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "saras ahīrī lē bhārjā",
      "translation_ru": "Взята также Сарас Ахири как рагини."
    },
    {
      "index": 25,
      "verse_id": 60371,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਗਿ ਲਾਈ ਪਾਂਚਉ ਆਰਜਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "saṅg lāī pāṅchau ārjā",
      "translation_ru": "Эти пять рагини соединены с Хиндолом: Теланги, Девкари, Басенти, Сандур и Сарас Ахири."
    },
    {
      "index": 26,
      "verse_id": 60372,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੁਰਮਾਨੰਦ ਭਾਸਕਰ ਆਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "surmānand bhāskar āe",
      "translation_ru": "Пришли Сурмананд и Бхаскар."
    },
    {
      "index": 27,
      "verse_id": 60373,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਚੰਦ੍ਰਬਿੰਬ ਮੰਗਲਨ ਸੁਹਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "chandrabimb maṅgalan suhāe",
      "translation_ru": "Также прекрасные Чандрабимб и Мангалан."
    },
    {
      "index": 28,
      "verse_id": 60374,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਰਸਬਾਨ ਅਉ ਆਹਿ ਬਿਨੋਦਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sarasbān au āh binodā",
      "translation_ru": "Сарасбан и Бинода также названы."
    },
    {
      "index": 29,
      "verse_id": 60375,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਾਵਹਿ ਸਰਸ ਬਸੰਤ ਕਮੋਦਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gāvah saras basant kamodā",
      "translation_ru": "Поются также Басанат и Камода."
    },
    {
      "index": 30,
      "verse_id": 60376,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਸਟ ਪੁਤ੍ਰ ਮੈ ਕਹੇ ਸਵਾਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "asaṭ putra mē kahe savārī",
      "translation_ru": "Так перечислены восемь сыновей Хиндола: Сурмананд, Бхаскар, Чандрабимб, Мангалан, Сарасбан, Бинода, Басант и Камода."
    },
    {
      "index": 31,
      "verse_id": 60377,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੁਨਿ ਆਈ ਦੀਪਕ ਕੀ ਬਾਰੀ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pun āī dīpak kī bārī",
      "translation_ru": "Затем пришла очередь рага Дипак."
    },
    {
      "index": 32,
      "verse_id": 60378,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਛੇਲੀ ਪਟਮੰਜਰੀ ਟੋਡੀ ਕਹੀ ਅਲਾਪਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kachhelī paṭmañjarī ṭoḍī kahī ālāp",
      "translation_ru": "Алапом названы Качхели, Патманджари и Тоди."
    },
    {
      "index": 33,
      "verse_id": 60379,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਾਮੋਦੀ ਅਉ ਗੂਜਰੀ ਸੰਗਿ ਦੀਪਕ ਕੇ ਥਾਪਿ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kāmodī au gūjrī saṅg dīpak ke thāp",
      "translation_ru": "Камоди и Гуджри установлены вместе с Дипаком; это пять рагини рага Дипак."
    },
    {
      "index": 34,
      "verse_id": 60380,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਾਲੰਕਾ ਕੁੰਤਲ ਅਉ ਰਾਮਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kālaṅkā kuntal au rāmā",
      "translation_ru": "Каланка, Кунтал и Рама."
    },
    {
      "index": 35,
      "verse_id": 60381,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਮਲਕੁਸਮ ਚੰਪਕ ਕੇ ਨਾਮਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kamalkusam champak ke nāmā",
      "translation_ru": "Также имена Камал Кусам и Чампак."
    },
    {
      "index": 36,
      "verse_id": 60382,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਉਰਾ ਅਉ ਕਾਨਰਾ ਕਲੵਾਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gaurā au kānrā kalyānā",
      "translation_ru": "Гаура, Канра и Кальяна."
    },
    {
      "index": 37,
      "verse_id": 60383,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਸਟ ਪੁਤ੍ਰ ਦੀਪਕ ਕੇ ਜਾਨਾ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "asaṭ putra dīpak ke jānā",
      "translation_ru": "Эти восемь известны как сыновья Дипака: Каланка, Кунтал, Рама, Камал Кусам, Чампак, Гаура, Канра и Кальяна."
    },
    {
      "index": 38,
      "verse_id": 60384,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਭ ਮਿਲਿ ਸਿਰੀਰਾਗ ਵੈ ਗਾਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sabh mil sirīrāg vē gāvah",
      "translation_ru": "Все вместе те знатоки поют Сирираг."
    },
    {
      "index": 39,
      "verse_id": 60385,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਂਚਉ ਸੰਗਿ ਬਰੰਗਨ ਲਾਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāṅchau saṅg baraṅgan lāvah",
      "translation_ru": "С ним соединяют пять рагини."
    },
    {
      "index": 40,
      "verse_id": 60386,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੈਰਾਰੀ ਕਰਨਾਟੀ ਧਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bērārī karnāṭī dharī",
      "translation_ru": "Установлены Байрари и Карнати."
    },
    {
      "index": 41,
      "verse_id": 60387,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਵਰੀ ਗਾਵਹਿ ਆਸਾਵਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gavrī gāvah āsāvarī",
      "translation_ru": "Поются Гаври и Асавари."
    },
    {
      "index": 42,
      "verse_id": 60388,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਹ ਪਾਛੈ ਸਿੰਧਵੀ ਅਲਾਪੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tih pāchhē siṅdhvī ālāpī",
      "translation_ru": "После них исполняется Синдхви."
    },
    {
      "index": 43,
      "verse_id": 60389,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਿਰੀਰਾਗ ਸਿਉ ਪਾਂਚਉ ਥਾਪੀ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sirīrāg siu pāṅchau thāpī",
      "translation_ru": "Эти пять рагини установлены вместе с Сирирагом: Байрари, Карнати, Гаври, Асавари и Синдхви."
    },
    {
      "index": 44,
      "verse_id": 60390,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਲੂ ਸਾਰਗ ਸਾਗਰਾ ਅਉਰ ਗੋਂਡ ਗੰਭੀਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sālū sārag sāgrā aur goṅḍ gambhīr",
      "translation_ru": "Салу, Сараг, Сагра, а также Гонд и Гамбхир."
    },
    {
      "index": 45,
      "verse_id": 60391,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਸਟ ਪੁਤ੍ਰ ਸ੍ਰੀਰਾਗ ਕੇ ਗੁੰਡ ਕੁੰਭ ਹਮੀਰ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "asaṭ putra srīrāg ke guṇḍ kumbh hamīr",
      "translation_ru": "Гунд, Кумбх и Хамир завершают восемь сыновей Срирага: Салу, Сараг, Сагра, Гонд, Гамбхир, Гунд, Кумбх и Хамир."
    },
    {
      "index": 46,
      "verse_id": 60392,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਖਸਟਮ ਮੇਘ ਰਾਗ ਵੈ ਗਾਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "khasṭam megh rāg vē gāvah",
      "translation_ru": "Шестым те знатоки поют раг Мегх."
    },
    {
      "index": 47,
      "verse_id": 60393,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਂਚਉ ਸੰਗਿ ਬਰੰਗਨ ਲਾਵਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāṅchau saṅg baraṅgan lāvah",
      "translation_ru": "С ним соединяют пять рагини."
    },
    {
      "index": 48,
      "verse_id": 60394,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਰਠਿ ਗੋਂਡ ਮਲਾਰੀ ਧੁਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "soraṭh goṅḍ malārī dhunī",
      "translation_ru": "Соратх, Гонд и мелодия Малари."
    },
    {
      "index": 49,
      "verse_id": 60395,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੁਨਿ ਗਾਵਹਿ ਆਸਾ ਗੁਨ ਗੁਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pun gāvah āsā gun gunī",
      "translation_ru": "Потом поётся Аса, полная достоинств."
    },
    {
      "index": 50,
      "verse_id": 60396,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਊਚੈ ਸੁਰਿ ਸੂਹਉ ਪੁਨਿ ਕੀਨੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ūchē sur sūhau pun kīnī",
      "translation_ru": "Затем высоким тоном исполняется Сухау."
    },
    {
      "index": 51,
      "verse_id": 60397,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੇਘ ਰਾਗ ਸਿਉ ਪਾਂਚਉ ਚੀਨੀ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "megh rāg siu pāṅchau chīnī",
      "translation_ru": "Эти пять распознаны как рагини рага Мегх: Соратх, Гонд, Малари, Аса и Сухау."
    },
    {
      "index": 52,
      "verse_id": 60398,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੈਰਾਧਰ ਗਜਧਰ ਕੇਦਾਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bērādhar gajdhar kedārā",
      "translation_ru": "Байрадхар, Гадждхар и Кедара."
    },
    {
      "index": 53,
      "verse_id": 60399,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਬਲੀਧਰ ਨਟ ਅਉ ਜਲਧਾਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jablīdhar naṭ au jaldhārā",
      "translation_ru": "Джаблидхар, Нат и Джалдхара."
    },
    {
      "index": 54,
      "verse_id": 60400,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪੁਨਿ ਗਾਵਹਿ ਸੰਕਰ ਅਉ ਸਿਆਮਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pun gāvah saṅkar au siāmā",
      "translation_ru": "Потом поются Санкар и Сьяма."
    },
    {
      "index": 55,
      "verse_id": 60401,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੇਘ ਰਾਗ ਪੁਤ੍ਰਨ ਕੇ ਨਾਮਾ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "megh rāg putran ke nāmā",
      "translation_ru": "Это имена восьми сыновей рага Мегх: Байрадхар, Гадждхар, Кедара, Джаблидхар, Нат, Джалдхара, Санкар и Сьяма."
    },
    {
      "index": 56,
      "verse_id": 60402,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਖਸਟ ਰਾਗ ਉਨਿ ਗਾਏ ਸੰਗਿ ਰਾਗਨੀ ਤੀਸ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "khasṭ rāg un gāe saṅg rāgnī tīs",
      "translation_ru": "Ими спеты шесть рагов вместе с тридцатью рагини."
    },
    {
      "index": 57,
      "verse_id": 60403,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਭੈ ਪੁਤ੍ਰ ਰਾਗੰਨ ਕੇ ਅਠਾਰਹ ਦਸ ਬੀਸ ॥੧॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sabhē putra rāgaṅn ke aṭhārah das bīs",
      "translation_ru": "А всех сыновей этих рагов — сорок восемь; общий счёт составляет шесть рагов, тридцать рагини и сорок восемь сыновей, всего восемьдесят четыре."
    }
  ]
}
