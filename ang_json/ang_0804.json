{
  "ang": 804,
  "line_count": 52,
  "lines": [
    {
      "index": 1,
      "verse_id": 34151,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਾਮਿ ਕ੍ਰੋਧਿ ਲੋਭਿ ਮੋਹਿ ਮਨੁ ਲੀਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kām krodh lobh moh man līnā.",
      "translation_ru": "Ум был поглощён похотью, гневом, жадностью и привязанностью."
    },
    {
      "index": 2,
      "verse_id": 34152,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਮੁਕਤਿ ਗੁਰਿ ਕੀਨਾ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bandhan kāṭ mukt gur kīnā. ||2||",
      "translation_ru": "Гуру разрубил эти узы и сделал меня освобождённым."
    },
    {
      "index": 3,
      "verse_id": 34153,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦੁਖ ਸੁਖ ਕਰਤ ਜਨਮਿ ਫੁਨਿ ਮੂਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dukh sukh karat janam phun mūā.",
      "translation_ru": "Переживая страдание и радость, человек снова рождался и умирал."
    },
    {
      "index": 4,
      "verse_id": 34154,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਚਰਨ ਕਮਲ ਗੁਰਿ ਆਸ੍ਰਮੁ ਦੀਆ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "charan kamal gur āsram dīā. ||3||",
      "translation_ru": "Гуру дал мне прибежище у лотосных стоп Господа."
    },
    {
      "index": 5,
      "verse_id": 34155,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਗਨਿ ਸਾਗਰ ਬੂਡਤ ਸੰਸਾਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "agan sāgar būḍat sansārā.",
      "translation_ru": "Мир тонет в огненном океане."
    },
    {
      "index": 6,
      "verse_id": 34156,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਬਾਹ ਪਕਰਿ ਸਤਿਗੁਰਿ ਨਿਸਤਾਰਾ ॥੪॥੩॥੮॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak bāh pakar satgur nistārā. ||4||3||8||",
      "translation_ru": "О Нанак, Сатгуру схватил меня за руку и переправил."
    },
    {
      "index": 7,
      "verse_id": 34157,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bilāval mahalā 5.",
      "translation_ru": "Билавал, Пятый Махала."
    },
    {
      "index": 8,
      "verse_id": 34158,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਨੁ ਮਨੁ ਧਨੁ ਅਰਪਉ ਸਭੁ ਅਪਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tan man dhan arpau sabh apnā.",
      "translation_ru": "Я готов отдать своё тело, свой ум, своё богатство — всё своё."
    },
    {
      "index": 9,
      "verse_id": 34159,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਵਨ ਸੁ ਮਤਿ ਜਿਤੁ ਹਰਿ ਹਰਿ ਜਪਨਾ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kavan su mat jit har har japnā. ||1||",
      "translation_ru": "Какая это добрая мудрость, благодаря которой можно повторять Имя Хар Хар?"
    },
    {
      "index": 10,
      "verse_id": 34160,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਿ ਆਸਾ ਆਇਓ ਪ੍ਰਭ ਮਾਗਨਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kar āsā āio prabh māgan.",
      "translation_ru": "О Господь, с надеждой я пришёл просить у Твоих дверей дар Твоего Имени."
    },
    {
      "index": 11,
      "verse_id": 34161,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤੁਮੑ ਪੇਖਤ ਸੋਭਾ ਮੇਰੈ ਆਗਨਿ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tumh pekhat sobhā merē āgan. ||1|| rahāu.",
      "translation_ru": "Когда я вижу Тебя, в моём сердечном дворе возникает радостное сияние. Пауза."
    },
    {
      "index": 12,
      "verse_id": 34162,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਨਿਕ ਜੁਗਤਿ ਕਰਿ ਬਹੁਤੁ ਬੀਚਾਰਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "anik jugat kar bahut bīchārau.",
      "translation_ru": "Я рассматриваю многие способы и долго размышляю."
    },
    {
      "index": 13,
      "verse_id": 34163,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧਸੰਗਿ ਇਸੁ ਮਨਹਿ ਉਧਾਰਉ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhsang is maneh udhārau. ||2||",
      "translation_ru": "И понимаю, что только в сангате гурмукхов могу спасти этот ум от пороков."
    },
    {
      "index": 14,
      "verse_id": 34164,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਤਿ ਬੁਧਿ ਸੁਰਤਿ ਨਾਹੀ ਚਤੁਰਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mat budh surat nāhī chaturāī.",
      "translation_ru": "Ни умением, ни рассудком, ни сосредоточением, ни какой-либо хитростью Господа не обрести."
    },
    {
      "index": 15,
      "verse_id": 34165,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਾ ਮਿਲੀਐ ਜਾ ਲਏ ਮਿਲਾਈ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tā milīai jā lae milāī. ||3||",
      "translation_ru": "С Ним можно соединиться лишь тогда, когда Он сам соединяет с Собой."
    },
    {
      "index": 16,
      "verse_id": 34166,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨੈਨ ਸੰਤੋਖੇ ਪ੍ਰਭ ਦਰਸਨੁ ਪਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nēn santokhe prabh darsan pāiā.",
      "translation_ru": "Тот, кто получил даршан Господа, чьи глаза насытились и освободились от жажды майи."
    },
    {
      "index": 17,
      "verse_id": 34167,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸਫਲੁ ਸੋ ਆਇਆ ॥੪॥੪॥੯॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kah nānak safal so āiā. ||4||4||9||",
      "translation_ru": "Скажи, Нанак: благословен и плодотворен приход такого человека в мир."
    },
    {
      "index": 18,
      "verse_id": 34168,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bilāval mahalā 5.",
      "translation_ru": "Билавал, Пятый Махала."
    },
    {
      "index": 19,
      "verse_id": 34169,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਾਤ ਪਿਤਾ ਸੁਤ ਸਾਥਿ ਨ ਮਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "māt pitā sut sāth na māiā.",
      "translation_ru": "Мать, отец, сын и майя не могут быть вечными спутниками человека и не помогают в страдании."
    },
    {
      "index": 20,
      "verse_id": 34170,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧਸੰਗਿ ਸਭੁ ਦੂਖੁ ਮਿਟਾਇਆ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhsang sabh dūkh miṭāiā. ||1||",
      "translation_ru": "Пребывая в сангате Гуру, можно устранить всё страдание и мучение."
    },
    {
      "index": 21,
      "verse_id": 34171,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਵਿ ਰਹਿਆ ਪ੍ਰਭੁ ਸਭ ਮਹਿ ਆਪੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rav rahiā prabh sabh meh āpe.",
      "translation_ru": "Господь Сам присутствует во всех существах."
    },
    {
      "index": 22,
      "verse_id": 34172,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਰਿ ਜਪੁ ਰਸਨਾ ਦੁਖੁ ਨ ਵਿਆਪੇ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "har jap rasnā dukh na viāpe. ||1|| rahāu.",
      "translation_ru": "Повторяй Его Имя языком — тогда никакое страдание не сможет одолеть тебя. Пауза."
    },
    {
      "index": 23,
      "verse_id": 34173,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਖਾ ਭੂਖ ਬਹੁ ਤਪਤਿ ਵਿਆਪਿਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tikhā bhūkh bah tapat viāpiā.",
      "translation_ru": "Мир охвачен жаждой майи, голодом майи и сильным внутренним жаром."
    },
    {
      "index": 24,
      "verse_id": 34174,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੀਤਲ ਭਏ ਹਰਿ ਹਰਿ ਜਸੁ ਜਾਪਿਆ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sītal bhae har har jas jāpiā. ||2||",
      "translation_ru": "Те, кто воспевает славу Хар Хар, становятся прохладными и умиротворёнными сердцем."
    },
    {
      "index": 25,
      "verse_id": 34175,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕੋਟਿ ਜਤਨ ਸੰਤੋਖੁ ਨ ਪਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "koṭ jatan santokh na pāiā.",
      "translation_ru": "Даже миллионами усилий не обрести удовлетворения от жажды майи."
    },
    {
      "index": 26,
      "verse_id": 34176,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨੁ ਤ੍ਰਿਪਤਾਨਾ ਹਰਿ ਗੁਣ ਗਾਇਆ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man triptānā har guṇ gāiā. ||3||",
      "translation_ru": "Когда поют добродетели Господа, ум насыщается и успокаивается."
    },
    {
      "index": 27,
      "verse_id": 34177,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦੇਹੁ ਭਗਤਿ ਪ੍ਰਭ ਅੰਤਰਜਾਮੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "deh bhagat prabh antarjāmī.",
      "translation_ru": "О Господь, знающий сердца, даруй мне Свою бхагти."
    },
    {
      "index": 28,
      "verse_id": 34178,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਨਕ ਕੀ ਬੇਨੰਤੀ ਸੁਆਮੀ ॥੪॥੫॥੧੦॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nānak kī benantī suāmī. ||4||5||10||",
      "translation_ru": "О Владыка, такова просьба Нанака у Твоих дверей."
    },
    {
      "index": 29,
      "verse_id": 34179,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bilāval mahalā 5.",
      "translation_ru": "Билавал, Пятый Махала."
    },
    {
      "index": 30,
      "verse_id": 34180,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਵਡਭਾਗੀ ਪਾਈਐ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur pūrā vaḍbhāgī pāīai.",
      "translation_ru": "Полный Гуру встречается только по великой судьбе."
    },
    {
      "index": 31,
      "verse_id": 34181,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਿਲਿ ਸਾਧੂ ਹਰਿ ਨਾਮੁ ਧਿਆਈਐ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mil sādhū har nām dhiāīai. ||1||",
      "translation_ru": "Встретив Гуру, можно медитировать на Имя Господа."
    },
    {
      "index": 32,
      "verse_id": 34182,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭ ਤੇਰੀ ਸਰਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pārbrahm prabh terī sarnā.",
      "translation_ru": "О Парабрахм, о Господь, я пришёл в Твоё прибежище."
    },
    {
      "index": 33,
      "verse_id": 34183,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਿਲਬਿਖ ਕਾਟੈ ਭਜੁ ਗੁਰ ਕੇ ਚਰਨਾ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kilbikh kāṭē bhaj gur ke charnā. ||1|| rahāu.",
      "translation_ru": "Прими в сердце опору у стоп Гуру: Гуру срезает все грехи. Пауза."
    },
    {
      "index": 34,
      "verse_id": 34184,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਵਰਿ ਕਰਮ ਸਭਿ ਲੋਕਾਚਾਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "avar karam sabh lokāchār.",
      "translation_ru": "Без прибежища Гуру все прочие дела — лишь внешний обычай мира."
    },
    {
      "index": 35,
      "verse_id": 34185,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਿਲਿ ਸਾਧੂ ਸੰਗਿ ਹੋਇ ਉਧਾਰ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "mil sādhū sang hoe udhār. ||2||",
      "translation_ru": "Лишь соединившись с сангатом Гуру, можно быть переправленным через мир-океан."
    },
    {
      "index": 36,
      "verse_id": 34186,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਿੰਮ੍ਰਿਤਿ ਸਾਸਤ ਬੇਦ ਬੀਚਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "siṃmrit sāstat bed bīchāre.",
      "translation_ru": "Я рассмотрел все шастры, смрити и Веды."
    },
    {
      "index": 37,
      "verse_id": 34187,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਪੀਐ ਨਾਮੁ ਜਿਤੁ ਪਾਰਿ ਉਤਾਰੇ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "japīai nām jit pār utāre. ||3||",
      "translation_ru": "Следует повторять Имя: через это Хар-Нам Гуру переправляет на другой берег."
    },
    {
      "index": 38,
      "verse_id": 34188,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਨ ਨਾਨਕ ਕਉ ਪ੍ਰਭ ਕਿਰਪਾ ਕਰੀਐ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jan nānak kau prabh kirpā karīai.",
      "translation_ru": "О Господь, прояви милость к Твоему слуге Нанаку."
    },
    {
      "index": 39,
      "verse_id": 34189,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧੂ ਧੂਰਿ ਮਿਲੈ ਨਿਸਤਰੀਐ ॥੪॥੬॥੧੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhū dhūr milē nistarīē. ||4||6||11||",
      "translation_ru": "Пусть мне достанется пыль стоп Гуру; только милостью Гуру можно переправиться."
    },
    {
      "index": 40,
      "verse_id": 34190,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bilāval mahalā 5.",
      "translation_ru": "Билавал, Пятый Махала."
    },
    {
      "index": 41,
      "verse_id": 34191,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਰਿਦੇ ਮਹਿ ਚੀਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gur kā sabad ride meh chīnā.",
      "translation_ru": "Те счастливцы, кто распознал и осмыслил Слово Гуру в своём сердце."
    },
    {
      "index": 42,
      "verse_id": 34192,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪੂਰਨ ਆਸੀਨਾ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagal manorath pūran āsīnā. ||1||",
      "translation_ru": "Все их желания исполнились, все их надежды достигли завершения."
    },
    {
      "index": 43,
      "verse_id": 34193,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੰਤ ਜਨਾ ਕਾ ਮੁਖੁ ਊਜਲੁ ਕੀਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sant janā kā mukh ūjal kīnā.",
      "translation_ru": "Господь сделал лик святых людей сияющим в этом мире и в ином."
    },
    {
      "index": 44,
      "verse_id": 34194,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪੁਨਾ ਨਾਮੁ ਦੀਨਾ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kar kirpā apunā nām dīnā. ||1|| rahāu.",
      "translation_ru": "Проявив милость, Он даровал им Своё Имя. Пауза."
    },
    {
      "index": 45,
      "verse_id": 34195,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅੰਧ ਕੂਪ ਤੇ ਕਰੁ ਗਹਿ ਲੀਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "andh kūp te kar geh līnā.",
      "translation_ru": "Господь взял их за руку и вывел из тёмного колодца привязанности к майе."
    },
    {
      "index": 46,
      "verse_id": 34196,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਜਗਤਿ ਪ੍ਰਗਟੀਨਾ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jē jē kār jagat pragṭīnā. ||2||",
      "translation_ru": "Их великая слава распространилась по всему миру."
    },
    {
      "index": 47,
      "verse_id": 34197,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨੀਚਾ ਤੇ ਊਚ ਊਨ ਪੂਰੀਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nīchā te ūch ūn pūrīnā.",
      "translation_ru": "Они из низких стали высокими, а пустые прежде наполнились добродетелями."
    },
    {
      "index": 48,
      "verse_id": 34198,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਮਹਾ ਰਸੁ ਲੀਨਾ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "amrit nām mahā ras līnā. ||3||",
      "translation_ru": "Они начали вкушать животворящее и велико-сладостное Имя Господа."
    },
    {
      "index": 49,
      "verse_id": 34199,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਤਨ ਨਿਰਮਲ ਪਾਪ ਜਲਿ ਖੀਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man tan nirmal pāp jal khīnā.",
      "translation_ru": "Их ум и тело стали чистыми, а все их грехи сгорели и исчезли."
    },
    {
      "index": 50,
      "verse_id": 34200,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪ੍ਰਭ ਭਏ ਪ੍ਰਸੀਨਾ ॥੪॥੭॥੧੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kah nānak prabh bhae prasīnā. ||4||7||12||",
      "translation_ru": "Скажи, Нанак: это происходит с теми, на кого Господь стал доволен."
    },
    {
      "index": 51,
      "verse_id": 34201,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bilāval mahalā 5.",
      "translation_ru": "Билавал, Пятый Махала."
    },
    {
      "index": 52,
      "verse_id": 34202,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪਾਈਅਹਿ ਮੀਤਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagal manorath pāīah mītā.",
      "translation_ru": "О друг, все желания обретаются и исполняются."
    }
  ]
}
