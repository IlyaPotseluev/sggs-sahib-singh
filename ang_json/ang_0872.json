{
  "ang": 872,
  "line_count": 60,
  "lines": [
    {
      "index": 1,
      "verse_id": 37005,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੋਂਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gonḍ.",
      "translation_ru": "Гонд."
    },
    {
      "index": 2,
      "verse_id": 37006,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗ੍ਰਿਹਿ ਸੋਭਾ ਜਾ ਕੈ ਰੇ ਨਾਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "grih sobhā jā kai rē nāh.",
      "translation_ru": "О брат, у того человека, в чьём доме нет майи — украшения дома,"
    },
    {
      "index": 3,
      "verse_id": 37007,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਵਤ ਪਹੀਆ ਖੂਧੇ ਜਾਹਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "āvat pahīā khūdhe jāh.",
      "translation_ru": "пришедшие путники уходят голодными."
    },
    {
      "index": 4,
      "verse_id": 37008,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਵਾ ਕੈ ਅੰਤਰਿ ਨਹੀ ਸੰਤੋਖੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "vā kai antar nahī santokh.",
      "translation_ru": "И в сердце хозяина такого дома нет утешения и довольства."
    },
    {
      "index": 5,
      "verse_id": 37009,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਸੋਹਾਗਨਿ ਲਾਗੈ ਦੋਖੁ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin sohāgan lāgai dokh. ||1||",
      "translation_ru": "Поэтому без этой майи, всегда пребывающей при своём Хозяине, на домохозяйство ложится упрёк. ||1||"
    },
    {
      "index": 6,
      "verse_id": 37010,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧਨੁ ਸੋਹਾਗਨਿ ਮਹਾ ਪਵੀਤ ॥ ਤਪੇ ਤਪੀਸਰ ਡੋਲੈ ਚੀਤ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhan sohāgan mahā pavīt. tape tapīsar ḍolai chīt. ||1|| rahāu.",
      "translation_ru": "Благословенна эта майя, всегда пребывающая при Хозяине; она велика и чиста, ибо без неё колеблется ум даже великих аскетов. ||1|| Пауза."
    },
    {
      "index": 7,
      "verse_id": 37011,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਹਾਗਨਿ ਕਿਰਪਨ ਕੀ ਪੂਤੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sohāgan kirpan kī pūtī.",
      "translation_ru": "Но эта майя становится дочерью скупца, то есть скупой лишь копит её и не пользуется ею."
    },
    {
      "index": 8,
      "verse_id": 37012,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੇਵਕ ਤਜਿ ਜਗਤ ਸਿਉ ਸੂਤੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sēvak taj jagat siu sūtī.",
      "translation_ru": "Оставив слуг Господа, она подчинила себе весь остальной мир."
    },
    {
      "index": 9,
      "verse_id": 37013,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧੂ ਕੈ ਠਾਢੀ ਦਰਬਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhū kai ṭhāḍhī darbār.",
      "translation_ru": "У двери святых она стоит и взывает."
    },
    {
      "index": 10,
      "verse_id": 37014,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਰਨਿ ਤੇਰੀ ਮੋ ਕਉ ਨਿਸਤਾਰਿ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "saran terī mo kau nistār. ||2||",
      "translation_ru": "Я пришла в твоё прибежище — спаси меня. ||2||"
    },
    {
      "index": 11,
      "verse_id": 37015,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਹਾਗਨਿ ਹੈ ਅਤਿ ਸੁੰਦਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sohāgan hai at sundarī.",
      "translation_ru": "Эта майя очень красива."
    },
    {
      "index": 12,
      "verse_id": 37016,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਗ ਨੇਵਰ ਛਨਕ ਛਨਹਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pag nēvar chhanak chhanharī.",
      "translation_ru": "На её ногах словно звенят браслеты — чхан-чхан."
    },
    {
      "index": 13,
      "verse_id": 37017,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਉ ਲਗੁ ਪ੍ਰਾਨ ਤਊ ਲਗੁ ਸੰਗੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jau lag prān taū lag sangē.",
      "translation_ru": "Пока в человеке есть жизнь, до тех пор она остаётся с ним."
    },
    {
      "index": 14,
      "verse_id": 37018,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਹਿ ਤ ਚਲੀ ਬੇਗਿ ਉਠਿ ਨੰਗੇ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nāh ta chalī bēg uṭh nangē. ||3||",
      "translation_ru": "Но как только жизнь уходит, она тоже тотчас убегает босиком, оставляя его. ||3||"
    },
    {
      "index": 15,
      "verse_id": 37019,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਹਾਗਨਿ ਭਵਨ ਤ੍ਰੈ ਲੀਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sohāgan bhavan trai līā.",
      "translation_ru": "Эта майя подчинила себе существ всех трёх миров."
    },
    {
      "index": 16,
      "verse_id": 37020,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦਸ ਅਠ ਪੁਰਾਣ ਤੀਰਥ ਰਸ ਕੀਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "das aṭh purāṇ tīrath ras kīā.",
      "translation_ru": "Она увлекла и тех, кто читает восемнадцать Пуран и ходит по местам паломничества."
    },
    {
      "index": 17,
      "verse_id": 37021,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬ੍ਰਹਮਾ ਬਿਸਨੁ ਮਹੇਸਰ ਬੇਧੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "brahmā bisan mahesar bēdhē.",
      "translation_ru": "Брахму, Вишну и Шиву она тоже пронзила своим влиянием."
    },
    {
      "index": 18,
      "verse_id": 37022,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਡੇ ਭੂਪਤਿ ਰਾਜੇ ਹੈ ਛੇਧੇ ॥੪॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "baḍe bhūpat rājē hai chhēdhē. ||4||",
      "translation_ru": "И великих властителей, царей и князей, она тоже держит в своих узах. ||4||"
    },
    {
      "index": 19,
      "verse_id": 37023,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋਹਾਗਨਿ ਉਰਵਾਰਿ ਨ ਪਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sohāgan urvār na pār.",
      "translation_ru": "Эта майя имеет огромный размах; ни ближнего, ни дальнего берега её не найти."
    },
    {
      "index": 20,
      "verse_id": 37024,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਂਚ ਨਾਰਦ ਕੈ ਸੰਗਿ ਬਿਧਵਾਰਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāñch nārad kai sang bidhvār.",
      "translation_ru": "Она тесно связана с пятью чувствами познания, которые вносят смятение в духовную жизнь человека."
    },
    {
      "index": 21,
      "verse_id": 37025,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਂਚ ਨਾਰਦ ਕੇ ਮਿਟਵੇ ਫੂਟੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāñch nārad kē miṭvē phūṭē.",
      "translation_ru": "Но мои пять глиняных сосудов чувств разбились, то есть влияние майи больше не действует на чувства."
    },
    {
      "index": 22,
      "verse_id": 37026,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਗੁਰ ਕਿਰਪਾ ਛੂਟੇ ॥੫॥੫॥੮॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kahu Kabīr gur kirpā chhūṭē. ||5||5||8||",
      "translation_ru": "Говорит Кабир: по милости Гуру я освободился от её удара. ||5||5||8||"
    },
    {
      "index": 23,
      "verse_id": 37027,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੋਂਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gonḍ.",
      "translation_ru": "Гонд."
    },
    {
      "index": 24,
      "verse_id": 37028,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਮੰਦਰ ਮਹਿ ਬਲਹਰ ਨਾ ਠਾਹਰੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jaisē mandar meh balhar nā ṭhāhrai.",
      "translation_ru": "Как крыша дома не может держаться без балки,"
    },
    {
      "index": 25,
      "verse_id": 37029,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕੈਸੇ ਪਾਰਿ ਉਤਰੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nām binā kaisē pār utarai.",
      "translation_ru": "так без Имени Господа человек не может переправиться через водовороты мирового океана."
    },
    {
      "index": 26,
      "verse_id": 37030,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕੁੰਭ ਬਿਨਾ ਜਲੁ ਨਾ ਟੀਕਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kumbh binā jal nā ṭīkāvai.",
      "translation_ru": "Как без кувшина вода не удерживается,"
    },
    {
      "index": 27,
      "verse_id": 37031,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧੂ ਬਿਨੁ ਐਸੇ ਅਬਗਤੁ ਜਾਵੈ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhū bin aisē abgat jāvai. ||1||",
      "translation_ru": "так без Гуру ум человека не утверждается, и человек уходит из мира в дурном состоянии. ||1||"
    },
    {
      "index": 28,
      "verse_id": 37032,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਾਰਉ ਤਿਸੈ ਜੁ ਰਾਮੁ ਨ ਚੇਤੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jārau tisai ju Rām na chētai.",
      "translation_ru": "Я сжёг бы тот ум, который не помнит Господа."
    },
    {
      "index": 29,
      "verse_id": 37033,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਨ ਮਨ ਰਮਤ ਰਹੈ ਮਹਿ ਖੇਤੈ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tan man ramat rahai meh khētai. ||1|| rahāu.",
      "translation_ru": "Он всем телом и умом остаётся погружён лишь в телесные наслаждения. ||1|| Пауза."
    },
    {
      "index": 30,
      "verse_id": 37034,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਹਲਹਰ ਬਿਨਾ ਜਿਮੀ ਨਹੀ ਬੋਈਐ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jaisē halhar binā jimī nahī boīai.",
      "translation_ru": "Как без земледельца нельзя засеять землю,"
    },
    {
      "index": 31,
      "verse_id": 37035,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੂਤ ਬਿਨਾ ਕੈਸੇ ਮਣੀ ਪਰੋਈਐ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sūt binā kaisē maṇī paroīai.",
      "translation_ru": "и как без нити нельзя нанизать бусины,"
    },
    {
      "index": 32,
      "verse_id": 37036,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਘੁੰਡੀ ਬਿਨੁ ਕਿਆ ਗੰਠਿ ਚੜ੍ਹਾਈਐ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ghuṇḍī bin kiā gaṇṭh chaṛhāīai.",
      "translation_ru": "и как без петли нельзя завязать узел,"
    },
    {
      "index": 33,
      "verse_id": 37037,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧੂ ਬਿਨੁ ਤੈਸੇ ਅਬਗਤੁ ਜਾਈਐ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhū bin taisē abgat jāīai. ||2||",
      "translation_ru": "так без прибежища Гуру человек уходит в дурном состоянии. ||2||"
    },
    {
      "index": 34,
      "verse_id": 37038,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਮਾਤ ਪਿਤਾ ਬਿਨੁ ਬਾਲੁ ਨ ਹੋਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jaisē māt pitā bin bāl na hoī.",
      "translation_ru": "Как без соединения матери и отца не рождается ребёнок,"
    },
    {
      "index": 35,
      "verse_id": 37039,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿੰਬ ਬਿਨਾ ਕੈਸੇ ਕਪਰੇ ਧੋਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bimb binā kaisē kaprē dhoī.",
      "translation_ru": "и как без воды не выстирать одежду,"
    },
    {
      "index": 36,
      "verse_id": 37040,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਘੋਰ ਬਿਨਾ ਕੈਸੇ ਅਸਵਾਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ghor binā kaisē asvār.",
      "translation_ru": "и как без коня человек не может называться всадником,"
    },
    {
      "index": 37,
      "verse_id": 37041,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਧੂ ਬਿਨੁ ਨਾਹੀ ਦਰਵਾਰ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sādhū bin nāhī darvār. ||3||",
      "translation_ru": "так без Гуру невозможно достичь Двора Господа. ||3||"
    },
    {
      "index": 38,
      "verse_id": 37042,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜੈਸੇ ਬਾਜੇ ਬਿਨੁ ਨਹੀ ਲੀਜੈ ਫੇਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jaisē bājē bin nahī lījai phērī.",
      "translation_ru": "Как без музыкальных инструментов не может быть танца,"
    },
    {
      "index": 39,
      "verse_id": 37043,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਖਸਮਿ ਦੁਹਾਗਨਿ ਤਜਿ ਅਉਹੇਰੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "khasam duhāgan taj auhērī.",
      "translation_ru": "так и без Хозяина женщина не может быть счастливой супругой; дурную жену Хозяин отвергает и презирает."
    },
    {
      "index": 40,
      "verse_id": 37044,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੈ ਕਬੀਰੁ ਏਕੈ ਕਰਿ ਕਰਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kahai Kabīr ēkai kar karnā.",
      "translation_ru": "Кабир говорит: делай одно единственное дело, достойное делания."
    },
    {
      "index": 41,
      "verse_id": 37045,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੁਰਮੁਖਿ ਹੋਇ ਬਹੁਰਿ ਨਹੀ ਮਰਨਾ ॥੪॥੬॥੯॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "gurmukh hoī bahur nahī marnā. ||4||6||9||",
      "translation_ru": "Стань обращённым к Гуру и повторяй Имя — тогда больше не придётся снова рождаться и умирать. ||4||6||9||"
    },
    {
      "index": 42,
      "verse_id": 37046,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗੋਂਡ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gonḍ.",
      "translation_ru": "Гонд."
    },
    {
      "index": 43,
      "verse_id": 37047,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕੂਟਨੁ ਸੋਇ ਜੁ ਮਨ ਕਉ ਕੂਟੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kūṭan soī ju man kau kūṭai.",
      "translation_ru": "Истинный «кутан» — тот, кто сокрушает свой собственный ум."
    },
    {
      "index": 44,
      "verse_id": 37048,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਕੂਟੈ ਤਉ ਜਮ ਤੇ ਛੂਟੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man kūṭai tau jam tē chhūṭai.",
      "translation_ru": "Когда человек сокрушает ум, он освобождается от ямов."
    },
    {
      "index": 45,
      "verse_id": 37049,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕੁਟਿ ਕੁਟਿ ਮਨੁ ਕਸਵਟੀ ਲਾਵੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kuṭ kuṭ man kasvaṭī lāvai.",
      "translation_ru": "Кто снова и снова усмиряет ум и проверяет его на пробном камне,"
    },
    {
      "index": 46,
      "verse_id": 37050,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋ ਕੂਟਨੁ ਮੁਕਤਿ ਬਹੁ ਪਾਵੈ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "so kūṭan mukat bahu pāvai. ||1||",
      "translation_ru": "тот, как сокрушающий свой ум «кутан», обретает освобождение. ||1||"
    },
    {
      "index": 47,
      "verse_id": 37051,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕੂਟਨੁ ਕਿਸੈ ਕਹਹੁ ਸੰਸਾਰ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kūṭan kisai kahahu sansār.",
      "translation_ru": "О люди мира, кого вы называете «кутан»?"
    },
    {
      "index": 48,
      "verse_id": 37052,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਬੋਲਨ ਕੇ ਮਾਹਿ ਬੀਚਾਰ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagal bolan kē māh bīchār. ||1|| rahāu.",
      "translation_ru": "Во всех словах могут быть разные смыслы и оттенки. ||1|| Пауза."
    },
    {
      "index": 49,
      "verse_id": 37053,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾਚਨੁ ਸੋਇ ਜੁ ਮਨ ਸਿਉ ਨਾਚੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nāchan soī ju man siu nāchai.",
      "translation_ru": "Истинный «начан» — тот, кто танцует не телом, а умом."
    },
    {
      "index": 50,
      "verse_id": 37054,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਝੂਠਿ ਨ ਪਤੀਐ ਪਰਚੈ ਸਾਚੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jhūṭh na patīai parchē sāchai.",
      "translation_ru": "Он не увлекается ложью, а утверждается в Истине."
    },
    {
      "index": 51,
      "verse_id": 37055,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਇਸੁ ਮਨ ਆਗੇ ਪੂਰੈ ਤਾਲ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "is man āgē pūrai tāl.",
      "translation_ru": "Он перед этим умом отбивает полный ритм, стараясь привести его в духовный восторг."
    },
    {
      "index": 52,
      "verse_id": 37056,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਇਸੁ ਨਾਚਨ ਕੇ ਮਨ ਰਖਵਾਲ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "is nāchan kē man rakhvāl. ||2||",
      "translation_ru": "Хранителем ума такого танцующего становится сам Господь. ||2||"
    },
    {
      "index": 53,
      "verse_id": 37057,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਜਾਰੀ ਸੋ ਜੁ ਬਜਾਰਹਿ ਸੋਧੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bajārī so ju bajāreh sodhai.",
      "translation_ru": "Истинный «базари» — тот, кто исследует рынок своего тела."
    },
    {
      "index": 54,
      "verse_id": 37058,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਂਚ ਪਲੀਤਹ ਕਉ ਪਰਬੋਧੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāñch palītah kau parbodhai.",
      "translation_ru": "Он пробуждает пять испорченных чувств познания."
    },
    {
      "index": 55,
      "verse_id": 37059,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਉ ਨਾਇਕ ਕੀ ਭਗਤਿ ਪਛਾਨੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nau nāik kī bhagat pachhānai.",
      "translation_ru": "Он учится распознавать путь поклонения Господу, Владыке девяти частей земли."
    },
    {
      "index": 56,
      "verse_id": 37060,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੋ ਬਾਜਾਰੀ ਹਮ ਗੁਰ ਮਾਨੇ ॥੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "so bājārī ham gur mānē. ||3||",
      "translation_ru": "Такого «базари» я считаю великим, превосходным человеком. ||3||"
    },
    {
      "index": 57,
      "verse_id": 37061,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਸਕਰੁ ਸੋਇ ਜਿ ਤਾਤਿ ਨ ਕਰੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "taskar soī ji tāt na karai.",
      "translation_ru": "Истинный «таскар» — тот, кто не держит в себе зависти, словно украл её из собственного ума."
    },
    {
      "index": 58,
      "verse_id": 37062,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਇੰਦ੍ਰੀ ਕੈ ਜਤਨਿ ਨਾਮੁ ਉਚਰੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "indrī kai jatan nām ucharai.",
      "translation_ru": "Обуздав чувства, он произносит Имя Господа."
    },
    {
      "index": 59,
      "verse_id": 37063,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਹਮ ਐਸੇ ਲਖਨ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kahu Kabīr ham aisē lakhan.",
      "translation_ru": "Говорит Кабир: эти признаки и качества я обрёл благодаря ему."
    },
    {
      "index": 60,
      "verse_id": 37064,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਧੰਨੁ ਗੁਰਦੇਵ ਅਤਿ ਰੂਪ ਬਿਚਖਨ ॥੪॥੭॥੧੦॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dhan gurdev at rūp bichakhan. ||4||7||10||",
      "translation_ru": "Благословен мой Гурдев — прекрасный, мудрый и достойный хвалы. ||4||7||10||"
    }
  ]
}